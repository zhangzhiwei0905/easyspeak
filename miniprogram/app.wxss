/**
 * EasySpeak - Global Styles
 * Design: Apple-inspired minimalism — clean, spacious, monochromatic
 */

/* ========================================
   CSS Variables
   ======================================== */
page {
  /* Light theme */
  --color-primary: #007AFF;
  --color-primary-dark: #0056CC;
  --color-primary-gradient: linear-gradient(135deg, #007AFF 0%, #0056CC 100%);
  --color-bg: #F5F5F7;
  --color-card: #ffffff;
  --color-accent: #007AFF;
  --color-text-primary: #1D1D1F;
  --color-text-secondary: #86868B;
  --color-text-hint: #AEAEB2;
  --color-border: #D2D2D7;
  --color-success: #34C759;
  --color-warning: #FF9F0A;
  --color-error: #FF3B30;

  /* Dark mode palette */
  --color-evening-primary: #F5F5F7;
  --color-evening-primary-dark: #98989D;
  --color-evening-bg: #000000;
  --color-evening-card: #1C1C1E;
  --color-evening-accent: #0A84FF;
  --color-evening-text: #F5F5F7;
  --color-evening-text-secondary: #98989D;
  --color-evening-border: #38383A;

  /* Typography */
  --font-size-small: 22rpx;
  --font-size-caption: 26rpx;
  --font-size-body: 30rpx;
  --font-size-title: 40rpx;
  --font-size-heading: 56rpx;
  --font-size-display: 68rpx;

  /* Letter spacing */
  --tracking-tight: -0.5rpx;
  --tracking-normal: 0;
  --tracking-wide: 1rpx;

  /* Spacing */
  --spacing-page: 32rpx;
  --spacing-card: 24rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* Border radius */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-card: 16rpx;
  --radius-round: 999rpx;

  /* Shadows — minimal, Apple-style with depth */
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-card-hover: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  --shadow-float: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);

  /* Base styles */
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  line-height: 1.5;
  letter-spacing: var(--tracking-normal);
  -webkit-font-smoothing: antialiased;
}

/* Dark mode support */
page.dark {
  --color-primary: #0A84FF;
  --color-primary-dark: #409CFF;
  --color-primary-gradient: linear-gradient(135deg, #0A84FF 0%, #409CFF 100%);
  --color-bg: #000000;
  --color-card: #1C1C1E;
  --color-accent: #0A84FF;
  --color-text-primary: #F5F5F7;
  --color-text-secondary: #98989D;
  --color-text-hint: #636366;
  --color-border: #38383A;
  --color-success: #30D158;
  --color-warning: #FFD60A;
  --color-error: #FF453A;
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.25);
  --shadow-card-hover: 0 4rpx 20rpx rgba(0, 0, 0, 0.35);
  --shadow-float: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

/* ========================================
   Typography
   ======================================== */
.text-display {
  font-size: var(--font-size-display);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: var(--tracking-tight);
}

.text-heading {
  font-size: var(--font-size-heading);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: var(--tracking-tight);
}

.text-title {
  font-size: var(--font-size-title);
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: var(--tracking-tight);
}

.text-body {
  font-size: var(--font-size-body);
  line-height: 1.5;
}

.text-caption {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.text-small {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
}

.text-medium {
  font-weight: 500;
}

.text-semibold {
  font-weight: 600;
}

.text-accent {
  color: var(--color-accent);
}

.text-primary {
  color: var(--color-primary);
}

.text-bold {
  font-weight: 600;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========================================
   Card Styles
   ======================================== */
.card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-lg);
  transition: box-shadow 0.25s ease, transform 0.2s ease;
}

.card:active {
  box-shadow: var(--shadow-card-hover);
  transform: scale(0.985);
}

.card-flat {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-lg);
}

.card-gradient {
  background: var(--color-primary-gradient);
  border-radius: var(--radius-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-lg);
  color: #ffffff;
}

.card-gradient .text-caption,
.card-gradient .text-small {
  color: rgba(255, 255, 255, 0.75);
}

/* ========================================
   Page Layout
   ======================================== */
.page {
  min-height: 100vh;
  padding: var(--spacing-page);
  box-sizing: border-box;
  background-color: var(--color-bg);
}

.page-no-padding {
  min-height: 100vh;
  background-color: var(--color-bg);
}

.page-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
  padding: var(--spacing-lg) 0 var(--spacing-md);
  color: var(--color-text-primary);
}

.section-title {
  font-size: var(--font-size-title);
  font-weight: 600;
  margin-bottom: var(--spacing-md);
  color: var(--color-text-primary);
}

.section {
  margin-bottom: var(--spacing-xl);
}

/* ========================================
   Flexbox Utilities
   ======================================== */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-start {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.flex-end {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.flex-1 {
  flex: 1;
}

.flex-shrink-0 {
  flex-shrink: 0;
}

.items-center {
  align-items: center;
}

.items-start {
  align-items: flex-start;
}

.items-end {
  align-items: flex-end;
}

.self-center {
  align-self: center;
}

/* ========================================
   Spacing Utilities
   ======================================== */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }

.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.mb-xl { margin-bottom: var(--spacing-xl); }

.ml-xs { margin-left: var(--spacing-xs); }
.ml-sm { margin-left: var(--spacing-sm); }
.ml-md { margin-left: var(--spacing-md); }
.ml-lg { margin-left: var(--spacing-lg); }

.mr-xs { margin-right: var(--spacing-xs); }
.mr-sm { margin-right: var(--spacing-sm); }
.mr-md { margin-right: var(--spacing-md); }
.mr-lg { margin-right: var(--spacing-lg); }

.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.p-xl { padding: var(--spacing-xl); }

/* ========================================
   Button Styles
   ======================================== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  border-radius: var(--radius-round);
  font-size: var(--font-size-body);
  font-weight: 500;
  border: none;
  transition: opacity 0.2s, transform 0.15s ease;
  line-height: 1.5;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-primary {
  background: var(--color-primary-gradient);
  color: #ffffff;
}

.btn-accent {
  background: var(--color-accent);
  color: #ffffff;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
}

.btn-block {
  display: flex;
  width: 100%;
}

.btn-sm {
  padding: 12rpx 32rpx;
  font-size: var(--font-size-caption);
}

.btn-lg {
  padding: 28rpx 64rpx;
  font-size: var(--font-size-title);
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ========================================
   Tag / Badge Styles
   ======================================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  font-size: var(--font-size-small);
  background: rgba(0, 122, 255, 0.08);
  color: var(--color-primary);
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: var(--radius-round);
  font-size: 20rpx;
  font-weight: 600;
  background: var(--color-error);
  color: #ffffff;
}

/* ========================================
   Progress Bar
   ======================================== */
.progress-bar {
  width: 100%;
  height: 16rpx;
  background: var(--color-border);
  border-radius: var(--radius-round);
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: var(--color-primary-gradient);
  border-radius: var(--radius-round);
  transition: width 0.3s ease;
}

/* ========================================
   Divider
   ======================================== */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: var(--spacing-md) 0;
}

/* ========================================
   Empty State
   ======================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--spacing-page);
}

.empty-state-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-lg);
  opacity: 0.4;
}

.empty-state-text {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

.empty-state-action {
  margin-top: var(--spacing-lg);
}

/* ========================================
   Animations
   ======================================== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(32rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.96); }
  to { opacity: 1; transform: scale(1); }
}

.animate-fade-in {
  animation: fadeIn 0.35s ease forwards;
}

.animate-slide-up {
  animation: slideUp 0.4s ease forwards;
}

.animate-scale-in {
  animation: scaleIn 0.3s ease forwards;
}

/* ========================================
   Safe Area
   ======================================== */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

/* ========================================
   Interactive Press Effect
   ======================================== */
.pressable {
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.pressable:active {
  transform: scale(0.97);
  opacity: 0.85;
}
