/**
 * EasySpeak - Global Styles
 * Design: Morning purple-blue (#667eea/#764ba2) / Evening dark-blue (#1a1a2e/#0f3460)
 */

/* ========================================
   CSS Variables
   ======================================== */
page {
  /* Morning theme (default) */
  --color-primary: #667eea;
  --color-primary-dark: #764ba2;
  --color-primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --color-bg: #f0f2f5;
  --color-card: #ffffff;
  --color-accent: #e8590c;
  --color-text-primary: #1a1a1a;
  --color-text-secondary: #666666;
  --color-text-hint: #999999;
  --color-border: #e8e8e8;
  --color-success: #52c41a;
  --color-warning: #faad14;
  --color-error: #ff4d4f;

  /* Evening theme (dark mode override) */
  --color-evening-primary: #1a1a2e;
  --color-evening-primary-dark: #0f3460;
  --color-evening-bg: #0d1117;
  --color-evening-card: #161b22;
  --color-evening-accent: #58a6ff;
  --color-evening-text: #c9d1d9;
  --color-evening-text-secondary: #8b949e;
  --color-evening-border: #30363d;

  /* Typography */
  --font-size-body: 28rpx;
  --font-size-caption: 24rpx;
  --font-size-title: 36rpx;
  --font-size-heading: 44rpx;
  --font-size-small: 22rpx;

  /* Spacing */
  --spacing-page: 32rpx;
  --spacing-card: 24rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* Border radius */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-card: 16rpx;
  --radius-round: 999rpx;

  /* Shadows */
  --shadow-card: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-card-hover: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  --shadow-float: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);

  /* Base styles */
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  line-height: 1.6;
}

/* Dark mode support */
page.dark {
  --color-primary: #58a6ff;
  --color-primary-dark: #1a1a2e;
  --color-primary-gradient: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
  --color-bg: #0d1117;
  --color-card: #161b22;
  --color-accent: #58a6ff;
  --color-text-primary: #c9d1d9;
  --color-text-secondary: #8b949e;
  --color-text-hint: #6e7681;
  --color-border: #30363d;
  --color-success: #3fb950;
  --color-warning: #d29922;
  --color-error: #f85149;
  --shadow-card: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  --shadow-card-hover: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  --shadow-float: 0 12rpx 32rpx rgba(0, 0, 0, 0.5);
}

/* ========================================
   Typography
   ======================================== */
.text-heading {
  font-size: var(--font-size-heading);
  font-weight: 700;
  line-height: 1.3;
}

.text-title {
  font-size: var(--font-size-title);
  font-weight: 600;
  line-height: 1.4;
}

.text-body {
  font-size: var(--font-size-body);
  line-height: 1.6;
}

.text-caption {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.text-small {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
}

.text-accent {
  color: var(--color-accent);
}

.text-primary {
  color: var(--color-primary);
}

.text-bold {
  font-weight: 600;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========================================
   Card Styles
   ======================================== */
.card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-lg);
  transition: box-shadow 0.2s ease;
}

.card:active {
  box-shadow: var(--shadow-card-hover);
}

.card-flat {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-lg);
}

.card-gradient {
  background: var(--color-primary-gradient);
  border-radius: var(--radius-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-lg);
  color: #ffffff;
}

.card-gradient .text-caption,
.card-gradient .text-small {
  color: rgba(255, 255, 255, 0.75);
}

/* ========================================
   Page Layout
   ======================================== */
.page {
  min-height: 100vh;
  padding: var(--spacing-page);
  box-sizing: border-box;
  background-color: var(--color-bg);
}

.page-no-padding {
  min-height: 100vh;
  background-color: var(--color-bg);
}

.page-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
  padding: var(--spacing-lg) 0 var(--spacing-md);
  color: var(--color-text-primary);
}

.section-title {
  font-size: var(--font-size-title);
  font-weight: 600;
  margin-bottom: var(--spacing-md);
  color: var(--color-text-primary);
}

.section {
  margin-bottom: var(--spacing-xl);
}

/* ========================================
   Flexbox Utilities
   ======================================== */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-start {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.flex-end {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.flex-1 {
  flex: 1;
}

.flex-shrink-0 {
  flex-shrink: 0;
}

.items-center {
  align-items: center;
}

.items-start {
  align-items: flex-start;
}

.items-end {
  align-items: flex-end;
}

.self-center {
  align-self: center;
}

/* ========================================
   Spacing Utilities
   ======================================== */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }

.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.mb-xl { margin-bottom: var(--spacing-xl); }

.ml-xs { margin-left: var(--spacing-xs); }
.ml-sm { margin-left: var(--spacing-sm); }
.ml-md { margin-left: var(--spacing-md); }
.ml-lg { margin-left: var(--spacing-lg); }

.mr-xs { margin-right: var(--spacing-xs); }
.mr-sm { margin-right: var(--spacing-sm); }
.mr-md { margin-right: var(--spacing-md); }
.mr-lg { margin-right: var(--spacing-lg); }

.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.p-xl { padding: var(--spacing-xl); }

/* ========================================
   Button Styles
   ======================================== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  border-radius: var(--radius-round);
  font-size: var(--font-size-body);
  font-weight: 500;
  border: none;
  transition: opacity 0.2s;
  line-height: 1.5;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.8;
}

.btn-primary {
  background: var(--color-primary-gradient);
  color: #ffffff;
}

.btn-accent {
  background: var(--color-accent);
  color: #ffffff;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
}

.btn-block {
  display: flex;
  width: 100%;
}

.btn-sm {
  padding: 12rpx 32rpx;
  font-size: var(--font-size-caption);
}

.btn-lg {
  padding: 28rpx 64rpx;
  font-size: var(--font-size-title);
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ========================================
   Tag / Badge Styles
   ======================================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  font-size: var(--font-size-small);
  background: rgba(102, 126, 234, 0.1);
  color: var(--color-primary);
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: var(--radius-round);
  font-size: 20rpx;
  font-weight: 600;
  background: var(--color-error);
  color: #ffffff;
}

/* ========================================
   Progress Bar
   ======================================== */
.progress-bar {
  width: 100%;
  height: 16rpx;
  background: var(--color-border);
  border-radius: var(--radius-round);
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: var(--color-primary-gradient);
  border-radius: var(--radius-round);
  transition: width 0.3s ease;
}

/* ========================================
   Divider
   ======================================== */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: var(--spacing-md) 0;
}

/* ========================================
   Empty State
   ======================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--spacing-page);
}

.empty-state-icon {
  font-size: 120rpx;
  margin-bottom: var(--spacing-lg);
}

.empty-state-text {
  font-size: var(--font-size-title);
  color: var(--color-text-hint);
}

/* ========================================
   Animations
   ======================================== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.animate-fade-in {
  animation: fadeIn 0.3s ease forwards;
}

.animate-slide-up {
  animation: slideUp 0.4s ease forwards;
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

/* ========================================
   Safe Area
   ======================================== */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}
