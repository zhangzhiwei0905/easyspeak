/* Calendar Component */
.calendar {
  width: 100%;
  box-sizing: border-box;
  background: transparent;
  border-radius: 0;
  padding: 0;
  box-shadow: none;
}

/* Header with navigation */
.calendar__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.calendar__nav-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, transform 0.15s ease;
}

.calendar__nav-btn:active {
  background: var(--color-border);
  transform: scale(0.95);
}

.calendar__nav-arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

.calendar__month-label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

/* Weekday row */
.calendar__weekdays {
  width: 100%;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 12rpx;
}

.calendar__weekday {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
}

.calendar__weekday-text {
  font-size: 24rpx;
  color: var(--color-text-hint);
  font-weight: 500;
}

/* Days grid */
.calendar__days {
  width: 100%;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}

.calendar__day {
  min-width: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 12rpx;
  transition: background 0.2s;
}

.calendar__day:not(.calendar__day--empty):active {
  background: var(--color-bg);
}

/* Empty cells */
.calendar__day--empty {
  pointer-events: none;
}

/* Day number */
.calendar__day-num {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 400;
  line-height: 1;
}

/* Today highlight */
.calendar__day--today {
  background: rgba(0, 122, 255, 0.08);
  border: 2rpx solid var(--color-primary);
  border-radius: 12rpx;
}

.calendar__day--today .calendar__day-num {
  color: var(--color-primary);
  font-weight: 700;
}

/* Has content: primary-blue dot */
.calendar__day--unlearned .calendar__day-num {
  color: var(--color-primary);
  font-weight: 500;
}

.calendar__day--unlearned {
  background: rgba(0, 122, 255, 0.06);
}

.calendar__day-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-top: 4rpx;
  position: absolute;
  bottom: 8rpx;
}

/* Studied: green dot */
.calendar__day--studied .calendar__day-num {
  color: var(--color-success);
  font-weight: 600;
}

.calendar__day-dot--green {
  background: var(--color-success);
}

/* Excellent: green solid fill */
.calendar__day--excellent {
  background: rgba(52, 199, 89, 0.12);
}

.calendar__day--excellent .calendar__day-num {
  color: var(--color-success);
  font-weight: 700;
}

.calendar__day-solid {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-success);
  position: absolute;
  bottom: 8rpx;
}

/* Review needed: warning dot */
.calendar__day--poor .calendar__day-num {
  color: var(--color-warning);
  font-weight: 600;
}

.calendar__day--reviewed .calendar__day-num {
  color: var(--color-error);
  font-weight: 600;
}

.calendar__day--reviewed {
  background: rgba(255, 59, 48, 0.06);
}

.calendar__day-dot--yellow {
  background: var(--color-warning);
}

/* Today + studied combined */
.calendar__day--today.calendar__day--studied {
  background: rgba(52, 199, 89, 0.08);
  border-color: var(--color-success);
}

.calendar__day--today.calendar__day--studied .calendar__day-num {
  color: var(--color-success);
}

.calendar__day--today.calendar__day--excellent {
  background: rgba(52, 199, 89, 0.12);
  border-color: var(--color-success);
}

.calendar__day--today.calendar__day--excellent .calendar__day-num {
  color: var(--color-success);
}

.calendar__day--today.calendar__day--unlearned {
  background: rgba(0, 122, 255, 0.06);
  border-color: var(--color-primary);
}

.calendar__day--today.calendar__day--unlearned .calendar__day-num {
  color: var(--color-primary);
}

.calendar__day--today.calendar__day--poor {
  background: rgba(255, 159, 10, 0.08);
  border-color: var(--color-warning);
}

.calendar__day--today.calendar__day--poor .calendar__day-num {
  color: var(--color-warning);
}

/* Review count badge */
.calendar__day-review {
  position: absolute;
  bottom: 4rpx;
  right: 2rpx;
  font-size: 16rpx;
  color: #ffffff;
  background: var(--color-error);
  border-radius: 999rpx;
  padding: 2rpx 6rpx;
  font-weight: 600;
  line-height: 1;
  min-width: 28rpx;
  text-align: center;
}

/* Legend */
.calendar__legend {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
}

.calendar__legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.calendar__legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.calendar__legend-dot--blue {
  background: var(--color-primary);
}

.calendar__legend-dot--green {
  background: var(--color-success);
}

.calendar__legend-dot--dark {
  background: var(--color-success);
}

.calendar__legend-dot--yellow {
  background: var(--color-warning);
}

.calendar__legend-dot--red {
  background: var(--color-error);
}

.calendar__legend-text {
  font-size: 20rpx;
  color: var(--color-text-hint);
}
