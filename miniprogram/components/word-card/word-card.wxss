/* Word Row Card - Expandable List Item */

.word-row {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: box-shadow 0.2s ease;
  overflow: hidden;
}

.word-row:active {
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
  background: #fafafa;
}

.word-row--expanded {
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.12);
  border: 1rpx solid rgba(102, 126, 234, 0.15);
}

/* ── Main row ── */
.word-row__main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.word-row__left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
  min-width: 0;
}

.word-row__word {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.word-row__pos {
  display: inline-block;
  font-size: 20rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-style: italic;
  flex-shrink: 0;
}

.word-row__right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  justify-content: flex-end;
  min-width: 0;
}

.word-row__meaning {
  font-size: 30rpx;
  font-weight: 500;
  color: #444;
  text-align: right;
  flex: 1;
  min-width: 0;
}

.word-row__arrow {
  font-size: 22rpx;
  color: #bbb;
  flex-shrink: 0;
  transition: transform 0.3s ease;
  display: inline-block;
}

.word-row__arrow--up {
  transform: rotate(180deg);
  color: #667eea;
}

/* ── Detail section (expanded) ── */
.word-row__detail {
  margin-top: 20rpx;
  animation: expandIn 0.25s ease;
}

@keyframes expandIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.word-row__phonetic {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.word-row__divider {
  height: 1rpx;
  background: rgba(102, 126, 234, 0.12);
  margin-bottom: 16rpx;
}

.word-row__example-block {
  background: #f8f9fc;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
}

.word-row__example-label {
  display: block;
  font-size: 20rpx;
  color: #aaa;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 10rpx;
}

.word-row__example {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  font-style: italic;
}
