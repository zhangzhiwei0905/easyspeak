/* Word Row Card - Expandable List Item — Apple Minimalism */

.word-row {
  background: var(--color-card);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  transition: box-shadow 0.2s ease;
  overflow: hidden;
}

.word-row:active {
  box-shadow: var(--shadow-card-hover);
  background: var(--color-bg);
}

.word-row--expanded {
  box-shadow: var(--shadow-card-hover);
  border: 1rpx solid var(--color-border);
}

/* ── Main row ── */
.word-row__main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.word-row__left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  min-width: 0;
}

.word-row__word {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
  flex-shrink: 0;
}

.word-row__pos {
  display: inline-block;
  font-size: 20rpx;
  color: var(--color-primary);
  background: rgba(0, 122, 255, 0.08);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-style: italic;
  flex-shrink: 0;
}

/* ── Speaker button (collapsed) ── */
.word-row__speaker {
  width: 56rpx;
  height: 40rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 2rpx;
  transition: background 0.15s;
}

.word-row__speaker:active {
  background: rgba(0, 122, 255, 0.08);
}

/* ── CSS Speaker Icon ── */
.speaker-icon {
  width: 36rpx;
  height: 30rpx;
  position: relative;
  display: flex;
  align-items: center;
}

.speaker-icon__body {
  width: 10rpx;
  height: 18rpx;
  border-radius: 3rpx;
  background: var(--color-text-secondary);
  position: relative;
  z-index: 2;
  flex-shrink: 0;
}

.speaker-icon__body::after {
  content: '';
  position: absolute;
  right: -6rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-right: 8rpx solid var(--color-text-secondary);
  border-left: none;
}

.speaker-icon__wave {
  position: absolute;
  left: 20rpx;
  border: 2rpx solid var(--color-text-secondary);
  border-left: none;
  border-radius: 0 50% 50% 0;
  opacity: 0;
  transition: opacity 0.15s;
}

.speaker-icon__wave--1 {
  width: 8rpx;
  height: 12rpx;
  top: 9rpx;
}

.speaker-icon__wave--2 {
  width: 14rpx;
  height: 20rpx;
  top: 5rpx;
}

.speaker-icon__wave--3 {
  width: 20rpx;
  height: 28rpx;
  top: 1rpx;
}

/* Playing wave animation */
.word-row__speaker--playing .speaker-icon__body,
.word-row__speaker--playing .speaker-icon__body::after {
  background: var(--color-primary);
  border-right-color: var(--color-primary);
}

.word-row__speaker--playing .speaker-icon__wave {
  border-color: var(--color-primary);
}

.word-row__speaker--playing .speaker-icon__wave--1 { opacity: 1; animation: wavePulse 0.8s ease-in-out infinite; }
.word-row__speaker--playing .speaker-icon__wave--2 { opacity: 1; animation: wavePulse 0.8s ease-in-out 0.15s infinite; }
.word-row__speaker--playing .speaker-icon__wave--3 { opacity: 1; animation: wavePulse 0.8s ease-in-out 0.3s infinite; }

@keyframes wavePulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.word-row__right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  justify-content: flex-end;
  min-width: 0;
}

.word-row__meaning {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  text-align: right;
  flex: 1;
  min-width: 0;
}

.word-row__arrow {
  font-size: 22rpx;
  color: var(--color-text-hint);
  flex-shrink: 0;
  transition: transform 0.3s ease;
  display: inline-block;
}

.word-row__arrow--up {
  transform: rotate(180deg);
  color: var(--color-primary);
}

/* ── Detail section (expanded) ── */
.word-row__detail {
  margin-top: 20rpx;
  animation: expandIn 0.25s ease;
}

@keyframes expandIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.word-row__phonetic-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.word-row__phonetic {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.word-row__accent-btns {
  display: flex;
  align-items: center;
  gap: 0;
  flex-shrink: 0;
}

.word-row__accent-btn {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-hint);
  padding: 8rpx 0;
  position: relative;
  transition: color 0.15s;
}

.word-row__accent-btn::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 2rpx;
  height: 2rpx;
  background: var(--color-primary);
  transform: scaleX(0);
  transition: transform 0.2s ease;
}

.word-row__accent-btn:active {
  color: var(--color-primary);
}

.word-row__accent-btn--active {
  color: var(--color-primary);
}

.word-row__accent-btn--active::after {
  transform: scaleX(1);
}

.word-row__accent-sep {
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin: 0 14rpx;
  opacity: 0.4;
}

.word-row__divider {
  height: 1rpx;
  background: var(--color-border);
  margin-bottom: 16rpx;
}

.word-row__example-block {
  background: var(--color-bg);
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid var(--color-primary);
  margin-bottom: 14rpx;
}

.word-row__example-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-hint);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 10rpx;
}

.word-row__example {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  font-style: italic;
}

.word-row__context-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: var(--color-bg);
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid rgba(0, 122, 255, 0.4);
}

.word-row__context {
  padding-top: 4rpx;
}

.word-row__context-copy {
  flex: 1;
  min-width: 0;
}

.word-row__context-meaning {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.word-row__context-example {
  display: block;
  margin-top: 4rpx;
  font-size: 23rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  font-style: italic;
}
