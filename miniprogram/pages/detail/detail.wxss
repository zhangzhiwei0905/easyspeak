/* ========================================
   Detail Page Styles
   ======================================== */

/* ---------- Skeleton Loading ---------- */
.skeleton {
  padding: 0;
}

.detail-page .skeleton__header {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-card);
  margin-bottom: var(--spacing-lg);
  background: var(--color-card);
  border-radius: var(--radius-card);
}

.detail-page .skeleton__circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 400% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.detail-page .skeleton__header-text {
  flex: 1;
}

.detail-page .skeleton__card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-lg);
}

.detail-page .skeleton__line {
  height: 28rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 400% 100%;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  animation: shimmer 1.5s ease-in-out infinite;
}

.detail-page .skeleton__line--short {
  width: 40%;
  margin-bottom: 0;
}

.detail-page .skeleton__line--title {
  width: 60%;
  height: 36rpx;
}

.detail-page .skeleton__line--body {
  width: 90%;
}

.detail-page .skeleton__line--long {
  width: 95%;
}

.detail-page .skeleton__line--medium {
  width: 70%;
  margin-bottom: 0;
}

.detail-page .skeleton__line--section {
  width: 40%;
  height: 32rpx;
  margin-bottom: 24rpx;
}

/* ---------- Error State ---------- */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx var(--spacing-page);
}

.error-state__icon {
  font-size: 120rpx;
  margin-bottom: var(--spacing-lg);
}

.error-state__text {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
  text-align: center;
}

/* ---------- Detail Header ---------- */
.detail-header {
  border-radius: var(--radius-card);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  color: #ffffff;
  position: relative;
  overflow: hidden;
}

.detail-header--morning {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.detail-header--evening {
  background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
}

.detail-header__top {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.detail-header__icon {
  font-size: 48rpx;
  margin-right: var(--spacing-sm);
}

.detail-header__info {
  display: flex;
  flex-direction: column;
}

.detail-header__slot {
  font-size: var(--font-size-caption);
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.4;
}

.detail-header__date {
  font-size: var(--font-size-small);
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.4;
}

.detail-header__theme {
  margin-bottom: var(--spacing-lg);
}

.detail-header__theme-zh {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  display: block;
}

.detail-header__theme-en {
  font-size: var(--font-size-body);
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
  margin-top: 8rpx;
  display: block;
}

.detail-header__stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-md);
  padding: 16rpx var(--spacing-card);
  backdrop-filter: blur(8px);
}

.detail-header__stat-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.detail-header__stat-num {
  font-size: var(--font-size-title);
  font-weight: 700;
  color: #ffffff;
}

.detail-header__stat-label {
  font-size: var(--font-size-caption);
  color: rgba(255, 255, 255, 0.75);
}

.detail-header__stat-divider {
  width: 2rpx;
  height: 32rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 var(--spacing-lg);
}

/* ---------- Section Label ---------- */
.detail-section {
  margin-bottom: var(--spacing-lg);
}

.section-label {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
  padding-left: 8rpx;
}

.section-label__icon {
  font-size: 30rpx;
  margin-right: 8rpx;
}

.section-label__text {
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

/* ---------- Intro / Tips Card ---------- */
.intro-card,
.tips-card {
  padding: var(--spacing-card);
}

.intro-card__text,
.tips-card__text {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* ---------- Tab Bar ---------- */
.tab-bar {
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-round);
  padding: 6rpx;
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

.tab-bar__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  border-radius: var(--radius-round);
  transition: all 0.3s ease;
}

.tab-bar__item--active {
  background: var(--color-primary-gradient);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.tab-bar__text {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.tab-bar__item--active .tab-bar__text {
  color: #ffffff;
}

/* ---------- Tab Content ---------- */
.tab-content {
  min-height: 200rpx;
}

/* ---------- Phrases List ---------- */
.phrases-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.phrase-wrapper {
  /* each phrase-card handles its own styling */
}

/* ---------- Words Grid ---------- */
.words-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.words-grid__item {
  /* word-card handles its own sizing */
}

/* ---------- List End Hint ---------- */
.list-end-hint {
  text-align: center;
  padding: var(--spacing-md) 0;
}

.list-end-hint__text {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
}

/* ---------- Empty Inline ---------- */
.empty-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-inline__text {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

/* ---------- Bottom Bar ---------- */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-card);
  padding: 20rpx var(--spacing-page);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.start-study-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-round);
  border: none;
  font-size: var(--font-size-title);
  font-weight: 600;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
  transition: all 0.3s ease;
  line-height: 1;
}

.start-study-btn::after {
  border: none;
}

.start-study-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.25);
}

.start-study-btn[disabled] {
  opacity: 1;
}

.start-study-btn--done {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
}

.start-study-btn__icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.start-study-btn__text {
  font-size: var(--font-size-title);
  color: #ffffff;
}
