/* ========================================
   Index Page Styles — Apple Minimalism
   ======================================== */

/* ---------- Skeleton Loading ---------- */
.skeleton {
  padding: 0;
}

.home-loading {
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx 32rpx;
}

.home-loading__dots {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.home-loading__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-primary);
  animation: homeDotBounce 1.2s ease-in-out infinite;
}

.home-loading__dot:nth-child(2) {
  animation-delay: 0.15s;
}

.home-loading__dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes homeDotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.home-loading__title {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  margin-bottom: 22rpx;
}

.home-loading__progress {
  width: 76%;
  max-width: 540rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.home-loading__track {
  flex: 1;
  height: 14rpx;
  background: var(--color-border);
  border-radius: 999rpx;
  overflow: hidden;
}

.home-loading__fill {
  height: 100%;
  border-radius: 999rpx;
  background: var(--color-primary-gradient);
  transition: width 0.24s ease;
  position: relative;
  overflow: hidden;
}

.home-loading__fill::after {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  width: 96rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.65), transparent);
  animation: homeProgressShimmer 1.1s ease-in-out infinite;
}

@keyframes homeProgressShimmer {
  from { transform: translateX(-110rpx); }
  to { transform: translateX(560rpx); }
}

.home-loading__value {
  width: 72rpx;
  text-align: right;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  font-variant-numeric: tabular-nums;
}

.home-loading__hint {
  font-size: 24rpx;
  color: var(--color-text-hint);
  text-align: center;
  line-height: 1.5;
}

.skeleton__card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-lg);
}

.skeleton__line {
  height: 28rpx;
  background: linear-gradient(90deg, var(--color-border) 25%, var(--color-border) 50%, var(--color-border) 75%);
  background-size: 400% 100%;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton__line--short {
  width: 40%;
  margin: 0 auto;
}

.skeleton__line--title {
  width: 60%;
  height: 36rpx;
}

.skeleton__line--body {
  width: 90%;
}

.skeleton__line--btn {
  width: 30%;
  height: 36rpx;
  margin-top: 16rpx;
  margin-bottom: 0;
}

.skeleton__line--section {
  width: 40%;
  height: 32rpx;
  margin-bottom: 24rpx;
}

.skeleton__line--long {
  width: 95%;
}

.skeleton__line--medium {
  width: 70%;
  margin-bottom: 0;
}

.skeleton__bar {
  height: 20rpx;
  background: linear-gradient(90deg, var(--color-border) 25%, var(--color-border) 50%, var(--color-border) 75%);
  background-size: 400% 100%;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton__rect {
  background: linear-gradient(90deg, var(--color-border) 25%, var(--color-border) 50%, var(--color-border) 75%);
  background-size: 400% 100%;
  border-radius: var(--radius-card);
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton__rect--word {
  width: 400rpx;
  height: 300rpx;
}

.skeleton__date-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 160rpx;
  margin-bottom: var(--spacing-lg);
}

@keyframes shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ---------- Error State ---------- */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx var(--spacing-page);
}

.error-state__icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-lg);
}

.error-state__icon-text {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
}

.error-state__text {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
  text-align: center;
}

/* ---------- Empty State Override ---------- */
.empty-state__icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-lg);
}

.empty-state__icon-line {
  font-size: 40rpx;
  font-weight: 300;
  color: var(--color-text-hint);
}

.empty-state__title {
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.empty-state__desc {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xs);
  text-align: center;
}

.empty-state__hint {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
}

/* ---------- Date Picker ---------- */
.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx var(--spacing-card);
  margin-bottom: var(--spacing-lg);
}

.date-picker__nav {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg);
  transition: background 0.2s;
}

.date-picker__nav:active {
  background: var(--color-border);
}

.date-picker__arrow {
  font-size: 44rpx;
  font-weight: 300;
  color: var(--color-text-primary);
  line-height: 1;
}

.date-picker__arrow--disabled {
  color: var(--color-text-hint);
  opacity: 0.4;
}

.date-picker__center {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.date-picker__date {
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--color-text-primary);
}

.date-picker__icon {
  color: var(--color-primary);
}

/* ========== Calendar Popup ========== */
.calendar-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 900;
  opacity: 0;
  animation: fadeIn 0.3s forwards;
}

.calendar-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-card);
  border-radius: 40rpx 40rpx 0 0;
  z-index: 1000;
  padding: var(--spacing-lg) var(--spacing-md) env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 -4rpx 30rpx rgba(0, 0, 0, 0.06);
}

.calendar-popup--show {
  transform: translateY(0);
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--spacing-md) var(--spacing-lg);
}

.calendar-nav {
  font-size: 40rpx;
  color: var(--color-text-primary);
  padding: 10rpx 30rpx;
  font-weight: 300;
}

.calendar-nav:active {
  opacity: 0.5;
}

.calendar-title {
  font-size: var(--font-size-h3);
  font-weight: bold;
  color: var(--color-text-primary);
}

.calendar-weekdays {
  display: flex;
  margin-bottom: var(--spacing-md);
}

.calendar-weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.calendar-day {
  width: 14.28%;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 10rpx;
  margin-bottom: var(--spacing-sm);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.calendar-day--empty {
  visibility: hidden;
}

.calendar-day--disabled {
  opacity: 0.3;
}

.calendar-day__num {
  font-size: var(--font-size-h4);
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.calendar-day__theme {
  font-size: 20rpx;
  color: var(--color-text-primary);
  text-align: center;
  width: 90%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  background: var(--color-bg);
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
}

.calendar-day--today .calendar-day__num {
  color: #fff;
  background: var(--color-primary);
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
}

.calendar-day--selected {
  background: rgba(0, 122, 255, 0.08);
}

.date-picker__time-slot {
  display: flex;
  background: var(--color-bg);
  border-radius: var(--radius-round);
  padding: 4rpx;
  margin-bottom: 8rpx;
}

.time-slot-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 28rpx;
  border-radius: var(--radius-round);
  transition: all 0.3s ease;
}

.time-slot-btn--active {
  background: var(--color-text-primary);
}

.time-slot-btn--active .time-slot-btn__text {
  color: #ffffff;
}

.time-slot-btn__icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.time-slot-btn__text {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.date-picker__date-text {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

/* ---------- Push Card — Light blue tint for hero ---------- */
.push-card {
  background: var(--color-primary-gradient);
  border-radius: var(--radius-card);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.push-card__header {
  margin-bottom: var(--spacing-md);
}

.push-card__theme {
  display: flex;
  flex-direction: column;
}

.push-card__theme-zh {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  letter-spacing: -0.5rpx;
}

.push-card__theme-en {
  font-size: var(--font-size-caption);
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.4;
  margin-top: 8rpx;
}

.push-card__intro {
  font-size: var(--font-size-body);
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.7;
  margin-bottom: var(--spacing-md);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.push-card__stats {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.push-card__stat {
  font-size: var(--font-size-caption);
  color: rgba(255, 255, 255, 0.7);
}

.push-card__stat-divider {
  margin: 0 12rpx;
  color: rgba(255, 255, 255, 0.4);
}

.push-card__action {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 16rpx 40rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-md);
  backdrop-filter: blur(8px);
  transition: background 0.2s;
}

.push-card__action:active {
  background: rgba(255, 255, 255, 0.35);
}

.push-card__action:active {
  opacity: 0.8;
}

.push-card__actions {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-top: 10rpx;
}

.push-card__btn-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.push-card__btn {
  display: inline-flex;
  align-items: center;
  padding: 20rpx 44rpx;
  border-radius: 999rpx;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.push-card__btn:active {
  transform: scale(0.95);
}

.push-card__btn--phrase {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-weight: 700;
  font-size: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.35);
}

.push-card__btn--phrase:active {
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.25);
}

.push-card__btn--word {
  background: linear-gradient(135deg, #4ECDC4 0%, #44B09E 100%);
  color: #ffffff;
  font-weight: 700;
  font-size: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(78, 205, 196, 0.35);
}

.push-card__btn--word:active {
  box-shadow: 0 2rpx 8rpx rgba(78, 205, 196, 0.25);
}

.push-card__btn-detail {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 12rpx;
  opacity: 0.9;
}

.push-card__btn-detail:active {
  opacity: 0.6;
}

.tomorrow-tip {
  margin: -8rpx var(--spacing-md) var(--spacing-lg);
  padding: 20rpx 28rpx;
  background: var(--color-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
}

.tomorrow-tip__label {
  display: inline;
  font-size: 22rpx;
  color: var(--color-text-hint);
  font-weight: 500;
}

.tomorrow-tip__main {
  display: flex;
  align-items: center;
}

.tomorrow-tip__text {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 12rpx;
}

.tomorrow-tip__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.tomorrow-tip__subtitle {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.push-card__btn-detail text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.push-card__btn-text {
  font-size: var(--font-size-body);
  color: #ffffff;
  font-weight: 500;
}

.push-card__btn-arrow {
  font-size: var(--font-size-body);
  color: #ffffff;
  margin-left: 8rpx;
}

/* ---------- Section Common ---------- */
.section {
  margin-bottom: var(--spacing-xl);
}

.section__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section__title-row {
  display: flex;
  align-items: center;
}

.section__title {
  font-size: var(--font-size-title);
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: -0.3rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid var(--color-primary);
}

.section__more {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
}

.section__more:active {
  opacity: 0.6;
}

.section__more-text {
  font-size: var(--font-size-caption);
  color: var(--color-text-primary);
}

.section__more-arrow {
  font-size: var(--font-size-caption);
  color: var(--color-text-primary);
  margin-left: 4rpx;
}

/* ---------- Phrases List ---------- */
.phrases-list {
  display: flex;
  flex-direction: column;
}

/* ---------- Words List ---------- */
.words-list {
  display: flex;
  flex-direction: column;
}

/* ---------- Progress Section ---------- */
.progress-section__content {
  padding: var(--spacing-card);
}

.progress-section__item {
  margin-bottom: var(--spacing-lg);
}

.progress-section__item:last-child {
  margin-bottom: 0;
}

.progress-section__label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-section__label-text {
  font-size: var(--font-size-body);
  font-weight: 500;
  color: var(--color-text-primary);
}

/* ---------- Review Section ---------- */
.review-card {
  padding: var(--spacing-card);
  border-left: 6rpx solid var(--color-primary);
}

.review-card__header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.review-card__title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.review-card__title {
  font-size: var(--font-size-title);
  font-weight: 700;
  color: var(--color-text-primary);
}

.review-card__desc {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: var(--spacing-md);
  display: block;
}

.review-card__action {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 40rpx;
  background: var(--color-primary);
  border-radius: var(--radius-md);
  transition: opacity 0.2s;
}

.review-card__action:active {
  opacity: 0.8;
}

.review-card__btn-text {
  font-size: var(--font-size-body);
  color: #ffffff;
  font-weight: 500;
}

.review-card__btn-arrow {
  font-size: var(--font-size-body);
  color: #ffffff;
  margin-left: 8rpx;
}

/* ---------- Review Done Card ---------- */
.review-done-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-card);
}

.review-done-card__text {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

/* ---------- Dark mode adjustments ---------- */
page.dark .skeleton__line,
page.dark .skeleton__bar,
page.dark .skeleton__rect {
  background: linear-gradient(90deg, #2C2C2E 25%, #3A3A3C 50%, #2C2C2E 75%);
  background-size: 400% 100%;
}

page.dark .date-picker {
  background: var(--color-card);
}

page.dark .date-picker__nav {
  background: var(--color-bg);
}

page.dark .date-picker__time-slot {
  background: var(--color-bg);
}

page.dark .calendar-day--today .calendar-day__num {
  background: var(--color-primary);
  color: #ffffff;
}

page.dark .review-card {
  border-left-color: var(--color-primary);
}

page.dark .review-card__action {
  background: var(--color-primary);
}

page.dark .review-card__btn-text,
page.dark .review-card__btn-arrow {
  color: #ffffff;
}

page.dark .push-card {
  background: linear-gradient(135deg, #0A84FF 0%, #5E5CE6 100%);
}

page.dark .push-card__action {
  background: rgba(255, 255, 255, 0.15);
}

page.dark .push-card__btn-text,
page.dark .push-card__btn-arrow {
  color: #ffffff;
}

page.dark .push-card__btn--phrase {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.2);
}

page.dark .push-card__btn--word {
  background: linear-gradient(135deg, #4ECDC4 0%, #44B09E 100%);
  box-shadow: 0 6rpx 20rpx rgba(78, 205, 196, 0.2);
}

page.dark .tomorrow-tip {
  border-color: var(--color-border);
}

page.dark .calendar-day__theme {
  background: #2C2C2E;
}

page.dark .calendar-day--selected {
  background: rgba(10, 132, 255, 0.12);
}
