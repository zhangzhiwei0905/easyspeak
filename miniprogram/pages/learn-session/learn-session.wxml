<!-- EasySpeak — Immersive Learning Session -->
<view class="learn-page">

  <!-- ========== Custom Navigation Bar ========== -->
  <view class="nav-bar">
    <view class="nav-bar__left" bindtap="onExit">
      <text class="nav-bar__close">✕</text>
    </view>
    <view class="nav-bar__center">
      <text class="nav-bar__title" wx:if="{{phase === 'learning'}}">{{stageLabels[stage]}} · {{learnType === 'phrase' ? '短语' : '单词'}}</text>
      <text class="nav-bar__title" wx:elif="{{phase === 'stage4'}}">掌握确认</text>
      <text class="nav-bar__title" wx:elif="{{phase === 'report'}}">学习报告</text>
    </view>
    <view class="nav-bar__right"></view>
  </view>

  <!-- ========== Loading ========== -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在准备学习内容...</text>
  </view>

  <!-- ========== Error ========== -->
  <view class="error-state" wx:if="{{loadError && !loading}}">
    <text class="error-state__icon">😞</text>
    <text class="error-state__text">{{errorMsg || '加载失败'}}</text>
    <view class="btn btn-primary" bindtap="onRetry">重新加载</view>
  </view>

  <!-- ========== Learning Phase (Stages 1-3) ========== -->
  <block wx:if="{{!loading && !loadError && phase === 'learning' && currentItem}}">

    <!-- Progress Bar -->
    <view class="progress-strip">
      <view class="progress-strip__track">
        <view class="progress-strip__fill progress-strip__fill--s{{stage}}"
              style="width: {{(currentIndex / queue.length) * 100}}%"></view>
      </view>
      <text class="progress-strip__text">{{currentIndex + 1}} / {{queue.length}}</text>
    </view>

    <!-- ======= Stage 1: Exposure ======= -->
    <view class="stage-card stage-exposure animate-fade-in" wx:if="{{stage === 1}}">
      <!-- Phrase exposure -->
      <block wx:if="{{learnType === 'phrase'}}">
        <view class="exposure__main-text">
          <text class="exposure__phrase">"{{currentItem.phrase}}"</text>
        </view>
        <view class="exposure__audio" bindtap="onPlayAudio">
          <text class="exposure__audio-icon">🔊</text>
          <text class="exposure__audio-label">点击听发音</text>
        </view>
        <view class="exposure__card">
          <view class="exposure__meaning-row">
            <text class="exposure__meaning-label">📖</text>
            <text class="exposure__meaning-text">{{currentItem.explanation}}</text>
          </view>
          <view class="exposure__example" wx:if="{{currentItem.example_en}}">
            <text class="exposure__example-label">💡 例句</text>
            <text class="exposure__example-en">"{{currentItem.example_en}}"</text>
            <text class="exposure__example-cn" wx:if="{{currentItem.example_cn}}">{{currentItem.example_cn}}</text>
          </view>
          <view class="exposure__source" wx:if="{{currentItem.source}}">
            <text class="exposure__source-text">📽 {{currentItem.source}}</text>
          </view>
        </view>
      </block>

      <!-- Word exposure -->
      <block wx:if="{{learnType === 'word'}}">
        <view class="exposure__main-text">
          <text class="exposure__word">{{currentItem.word}}</text>
          <text class="exposure__phonetic" wx:if="{{currentItem.phonetic}}">{{currentItem.phonetic}}</text>
        </view>
        <view class="exposure__audio" bindtap="onPlayAudio">
          <text class="exposure__audio-icon">🔊</text>
          <text class="exposure__audio-label">点击听发音</text>
        </view>
        <view class="exposure__card">
          <view class="exposure__pos" wx:if="{{currentItem.part_of_speech}}">
            <text class="exposure__pos-tag">{{currentItem.part_of_speech}}</text>
          </view>
          <view class="exposure__meaning-row">
            <text class="exposure__meaning-label">📖</text>
            <text class="exposure__meaning-text">{{currentItem.meaning}}</text>
          </view>
          <view class="exposure__example" wx:if="{{currentItem.example}}">
            <text class="exposure__example-label">💡 例句</text>
            <text class="exposure__example-en">"{{currentItem.example}}"</text>
          </view>
        </view>
      </block>

      <!-- Next button -->
      <view class="stage-action">
        <view class="btn btn-next {{canProceed ? '' : 'btn--disabled'}}" bindtap="onExposureNext">
          <text class="btn__text">{{canProceed ? '我记住了，下一步 →' : '请认真阅读...'}}</text>
        </view>
      </view>
    </view>

    <!-- ======= Stage 2 & 3: Quiz ======= -->
    <view class="stage-card stage-quiz animate-fade-in" wx:if="{{stage === 2 || stage === 3}}">
      <view class="quiz__question">
        <text class="quiz__question-text">{{quizData.question}}</text>
        <text class="quiz__hint" wx:if="{{quizData.hint}}">💡 提示：{{quizData.hint}}</text>
      </view>

      <view class="quiz__options">
        <view class="quiz__option {{selectedKey === opt.key ? 'quiz__option--selected' : ''}} {{submitted && opt.key === quizData.answer ? 'quiz__option--correct' : ''}} {{submitted && selectedKey === opt.key && !isCorrect ? 'quiz__option--wrong' : ''}}"
              wx:for="{{quizData.options}}"
              wx:for-item="opt"
              wx:key="key"
              data-key="{{opt.key}}"
              bindtap="onSelectOption">
          <text class="quiz__option-key">{{opt.key}}</text>
          <text class="quiz__option-text">{{opt.text}}</text>
          <text class="quiz__option-icon" wx:if="{{submitted && opt.key === quizData.answer}}">✓</text>
          <text class="quiz__option-icon quiz__option-icon--wrong" wx:if="{{submitted && selectedKey === opt.key && !isCorrect}}">✗</text>
        </view>
      </view>

      <!-- Feedback -->
      <view class="quiz__feedback" wx:if="{{submitted}}">
        <view class="quiz__feedback-banner {{isCorrect ? 'quiz__feedback-banner--correct' : 'quiz__feedback-banner--wrong'}}">
          <text class="quiz__feedback-emoji">{{isCorrect ? '🎉' : '😅'}}</text>
          <text class="quiz__feedback-text">{{isCorrect ? '太棒了！回答正确' : '答错了，正确答案是 ' + correctOptionText}}</text>
        </view>
      </view>

      <!-- Action buttons -->
      <view class="stage-action">
        <view class="btn btn-primary" bindtap="onSubmitAnswer" wx:if="{{!submitted}}">
          <text class="btn__text">确认答案</text>
        </view>
        <view class="btn btn-next" bindtap="onQuizNext" wx:if="{{submitted}}">
          <text class="btn__text">下一步 →</text>
        </view>
      </view>
    </view>

  </block>

  <!-- ========== Stage 4: Mastery Recall ========== -->
  <block wx:if="{{phase === 'stage4' && stage4Item}}">

    <!-- Progress -->
    <view class="progress-strip">
      <view class="progress-strip__track">
        <view class="progress-strip__fill progress-strip__fill--s4"
              style="width: {{(stage4Index / stage4Items.length) * 100}}%"></view>
      </view>
      <text class="progress-strip__text">🧠 最终确认 {{stage4Index + 1}} / {{stage4Items.length}}</text>
    </view>

    <view class="stage-card stage-mastery animate-fade-in">
      <!-- Front: Chinese prompt -->
      <view class="mastery__prompt">
        <text class="mastery__prompt-label">你还记得这个{{learnType === 'phrase' ? '短语' : '单词'}}吗？</text>
        <view class="mastery__chinese">
          <text class="mastery__chinese-text" wx:if="{{learnType === 'phrase'}}">{{stage4Item.meaning || stage4Item.explanation}}</text>
          <text class="mastery__chinese-text" wx:if="{{learnType === 'word'}}">{{stage4Item.meaning}}</text>
        </view>
      </view>

      <!-- Flip button / Revealed answer -->
      <view class="mastery__reveal" wx:if="{{stage4Mode === 'self' && !stage4Flipped}}">
        <view class="btn btn-flip" bindtap="onFlipCard">
          <text class="btn__text">👀 点击显示答案</text>
        </view>
      </view>

      <view class="mastery__word-select" wx:if="{{stage4Mode === 'word_select'}}">
        <text class="mastery__ws-label">请选择正确的单词组成短语</text>

        <!-- Answer slots -->
        <view class="mastery__ws-slots">
          <view class="mastery__ws-slot {{slot.isCorrect === true ? 'mastery__ws-slot--correct' : ''}} {{slot.isCorrect === false ? 'mastery__ws-slot--wrong' : ''}} {{slot.text && !wordSelectSubmitted ? 'mastery__ws-slot--filled' : ''}}"
                wx:for="{{wordSlots}}"
                wx:for-item="slot"
                wx:key="index"
                data-index="{{index}}"
                bindtap="onSlotTap">
            <text wx:if="{{slot.text}}">{{slot.text}}</text>
            <text wx:else class="mastery__ws-slot-placeholder">+</text>
          </view>
        </view>

        <!-- Next button after submission -->
        <view class="stage-action" wx:if="{{wordSelectSubmitted}}">
          <view class="btn btn-next" bindtap="onWordSelectNext">
            <text class="btn__text">下一题 →</text>
          </view>
        </view>
      </view>

      <!-- Available word tiles -->
      <view class="mastery__ws-tiles" wx:if="{{stage4Mode === 'word_select' && !wordSelectSubmitted}}">
        <view class="mastery__ws-tile {{tile.used ? 'mastery__ws-tile--used' : ''}}"
              wx:for="{{availableTiles}}"
              wx:for-item="tile"
              wx:key="index"
              data-index="{{index}}"
              bindtap="onWordTileTap">
          <text>{{tile.text}}</text>
        </view>
      </view>

      <view class="mastery__answer animate-flip-in" wx:if="{{stage4Flipped}}">
        <view class="mastery__answer-card">
          <text class="mastery__answer-text" wx:if="{{learnType === 'phrase'}}">"{{stage4Item.phrase}}"</text>
          <text class="mastery__answer-text" wx:if="{{learnType === 'word'}}">{{stage4Item.word}}</text>
          <text class="mastery__answer-phonetic" wx:if="{{learnType === 'word' && stage4Item.phonetic}}">{{stage4Item.phonetic}}</text>
          <view class="mastery__answer-audio" bindtap="onPlayAudio">
            <text>🔊 听发音</text>
          </view>
        </view>

        <!-- Self-assessment buttons -->
        <block wx:if="{{stage4Mode === 'self'}}">
        <view class="mastery__assess-label">
          <text>你记住了吗？</text>
        </view>
        <view class="mastery__assess-btns">
          <view class="mastery__btn mastery__btn--forgot" data-mastery="0" bindtap="onMasterySelect">
            <text class="mastery__btn-emoji">😫</text>
            <text class="mastery__btn-label">忘了</text>
          </view>
          <view class="mastery__btn mastery__btn--fuzzy" data-mastery="1" bindtap="onMasterySelect">
            <text class="mastery__btn-emoji">😕</text>
            <text class="mastery__btn-label">模糊</text>
          </view>
          <view class="mastery__btn mastery__btn--remembered" data-mastery="3" bindtap="onMasterySelect">
            <text class="mastery__btn-emoji">😊</text>
            <text class="mastery__btn-label">记住了</text>
          </view>
          <view class="mastery__btn mastery__btn--solid" data-mastery="4" bindtap="onMasterySelect">
            <text class="mastery__btn-emoji">🎯</text>
            <text class="mastery__btn-label">牢记</text>
          </view>
        </view>
        </block>
      </view>
    </view>

  </block>

  <!-- ========== Report ========== -->
  <block wx:if="{{phase === 'report' && report}}">
    <view class="report animate-fade-in">
      <view class="report__header">
        <text class="report__title-emoji">🎉</text>
        <text class="report__title">学习完成！</text>
        <text class="report__subtitle">{{themeZh}} · {{learnType === 'phrase' ? '短语' : '单词'}}</text>
      </view>

      <!-- Stats card -->
      <view class="report__card">
        <text class="report__card-title">📊 学习报告</text>
        <view class="report__stat-grid">
          <view class="report__stat">
            <text class="report__stat-icon">⏱️</text>
            <text class="report__stat-label">学习用时</text>
            <text class="report__stat-value">{{report.durationDisplay}}</text>
          </view>
          <view class="report__stat">
            <text class="report__stat-icon">📝</text>
            <text class="report__stat-label">学习项目</text>
            <text class="report__stat-value">{{report.totalItems}} 项</text>
          </view>
          <view class="report__stat">
            <text class="report__stat-icon">🎯</text>
            <text class="report__stat-label">一次通过率</text>
            <text class="report__stat-value">{{report.firstPassRate}}%</text>
          </view>
          <view class="report__stat">
            <text class="report__stat-icon">✅</text>
            <text class="report__stat-label">最终通过率</text>
            <text class="report__stat-value">{{report.finalPassRate}}%</text>
          </view>
        </view>
      </view>

      <!-- Mastery distribution -->
      <view class="report__card">
        <text class="report__card-title">🧠 掌握度分布</text>
        <view class="report__dist">
          <view class="report__dist-row">
            <text class="report__dist-emoji">🎯</text>
            <text class="report__dist-label">牢记</text>
            <view class="report__dist-bar-wrap">
              <view class="report__dist-bar report__dist-bar--solid"
                    style="width: {{report.totalItems > 0 ? (report.distribution.solid / report.totalItems) * 100 : 0}}%"></view>
            </view>
            <text class="report__dist-count">{{report.distribution.solid}}</text>
          </view>
          <view class="report__dist-row">
            <text class="report__dist-emoji">😊</text>
            <text class="report__dist-label">记住了</text>
            <view class="report__dist-bar-wrap">
              <view class="report__dist-bar report__dist-bar--remembered"
                    style="width: {{report.totalItems > 0 ? (report.distribution.remembered / report.totalItems) * 100 : 0}}%"></view>
            </view>
            <text class="report__dist-count">{{report.distribution.remembered}}</text>
          </view>
          <view class="report__dist-row">
            <text class="report__dist-emoji">😕</text>
            <text class="report__dist-label">模糊</text>
            <view class="report__dist-bar-wrap">
              <view class="report__dist-bar report__dist-bar--fuzzy"
                    style="width: {{report.totalItems > 0 ? (report.distribution.fuzzy / report.totalItems) * 100 : 0}}%"></view>
            </view>
            <text class="report__dist-count">{{report.distribution.fuzzy}}</text>
          </view>
          <view class="report__dist-row">
            <text class="report__dist-emoji">😫</text>
            <text class="report__dist-label">忘了</text>
            <view class="report__dist-bar-wrap">
              <view class="report__dist-bar report__dist-bar--forgot"
                    style="width: {{report.totalItems > 0 ? (report.distribution.forgot / report.totalItems) * 100 : 0}}%"></view>
            </view>
            <text class="report__dist-count">{{report.distribution.forgot}}</text>
          </view>
        </view>
      </view>

      <!-- Streak -->
      <view class="report__streak" wx:if="{{report.studyStreak}}">
        <text class="report__streak-text">🔥 连续学习 {{report.studyStreak}} 天！</text>
      </view>

      <!-- Actions -->
      <view class="report__actions">
        <view class="btn btn-share" bindtap="onShareResult">
          <text class="btn__text">📤 分享成绩</text>
        </view>
        <view class="btn btn-primary" bindtap="onBackToHome">
          <text class="btn__text">🏠 返回首页</text>
        </view>
      </view>
    </view>
  </block>

  <!-- Bottom safe area -->
  <view style="height: 80rpx;"></view>
</view>
