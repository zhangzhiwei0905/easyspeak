/**
 * EasySpeak — Immersive Learning Session Styles
 * Full-screen, light-themed immersive design
 */

/* ============================================
   Page & Layout
   ============================================ */
.learn-page {
  min-height: 100vh;
  background: #f6f7fb;
  color: #1a1a2e;
  padding-top: 0;
  box-sizing: border-box;
}

/* ============================================
   Custom Navigation Bar
   ============================================ */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 32rpx 24rpx;
  position: relative;
  z-index: 10;
}

.nav-bar__left {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-bar__close {
  font-size: 40rpx;
  color: #667085;
  font-weight: 300;
}

.nav-bar__center {
  flex: 1;
  text-align: center;
}

.nav-bar__title {
  font-size: 30rpx;
  color: #475467;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.nav-bar__right {
  width: 80rpx;
}

/* ============================================
   Loading & Error States
   ============================================ */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.2);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #667085;
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 250rpx;
  gap: 24rpx;
}

.error-state__icon {
  font-size: 80rpx;
}

.error-state__text {
  font-size: 30rpx;
  color: #667085;
}

/* ============================================
   Progress Strip
   ============================================ */
.progress-strip {
  padding: 0 32rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-strip__track {
  flex: 1;
  height: 8rpx;
  background: #e9ecf3;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-strip__fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.4s ease;
}

.progress-strip__fill--s1 {
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.progress-strip__fill--s2 {
  background: linear-gradient(90deg, #f093fb, #f5576c);
}

.progress-strip__fill--s3 {
  background: linear-gradient(90deg, #4facfe, #00f2fe);
}

.progress-strip__fill--s4 {
  background: linear-gradient(90deg, #43e97b, #38f9d7);
}

.progress-strip__text {
  font-size: 24rpx;
  color: #667085;
  white-space: nowrap;
}

/* ============================================
   Stage Card (shared container)
   ============================================ */
.stage-card {
  margin: 0 32rpx;
  padding: 40rpx 32rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(16, 24, 40, 0.08);
}

/* ============================================
   Stage 1: Exposure
   ============================================ */
.exposure__main-text {
  text-align: center;
  padding: 40rpx 0 8rpx;
}

.exposure__phrase {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.4;
}

.exposure__word {
  font-size: 56rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.exposure__phonetic {
  display: block;
  margin-top: 12rpx;
  font-size: 30rpx;
  color: #667085;
  font-weight: 400;
}

.exposure__audio {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0 32rpx;
}

.exposure__audio-icon {
  font-size: 36rpx;
}

.exposure__audio-label {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

.exposure__card {
  background: #f8f9fc;
  border: 1rpx solid #edf0f6;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 12rpx;
}

.exposure__pos {
  margin-bottom: 16rpx;
}

.exposure__pos-tag {
  display: inline-block;
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.exposure__meaning-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.exposure__meaning-label {
  font-size: 28rpx;
  flex-shrink: 0;
}

.exposure__meaning-text {
  font-size: 28rpx;
  color: #344054;
  line-height: 1.6;
}

.exposure__example {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #edf0f6;
}

.exposure__example-label {
  display: block;
  font-size: 24rpx;
  color: #667085;
  margin-bottom: 8rpx;
}

.exposure__example-en {
  display: block;
  font-size: 28rpx;
  color: #344054;
  font-style: italic;
  line-height: 1.5;
}

.exposure__example-cn {
  display: block;
  font-size: 26rpx;
  color: #667085;
  margin-top: 8rpx;
}

.exposure__source {
  margin-top: 16rpx;
}

.exposure__source-text {
  font-size: 24rpx;
  color: #98a2b3;
}

/* ============================================
   Stage 2 & 3: Quiz
   ============================================ */
.quiz__question {
  padding: 20rpx 0 40rpx;
}

.quiz__question-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.5;
  display: block;
}

.quiz__hint {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #667eea;
}

.quiz__options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.quiz__option {
  display: flex;
  align-items: center;
  background: #f8f9fc;
  border: 2rpx solid #edf0f6;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  transition: all 0.2s ease;
}

.quiz__option--selected {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.1);
}

.quiz__option--correct {
  border-color: #3fb950 !important;
  background: rgba(63, 185, 80, 0.12) !important;
}

.quiz__option--wrong {
  border-color: #f85149 !important;
  background: rgba(248, 81, 73, 0.12) !important;
}

.quiz__option-key {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #667085;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.quiz__option--selected .quiz__option-key {
  background: #667eea;
  color: #ffffff;
}

.quiz__option--correct .quiz__option-key {
  background: #3fb950;
  color: #ffffff;
}

.quiz__option--wrong .quiz__option-key {
  background: #f85149;
  color: #ffffff;
}

.quiz__option-text {
  flex: 1;
  font-size: 30rpx;
  color: #344054;
  line-height: 1.4;
}

.quiz__option-icon {
  font-size: 32rpx;
  color: #3fb950;
  margin-left: 12rpx;
  font-weight: 700;
}

.quiz__option-icon--wrong {
  color: #f85149;
}

/* Quiz Feedback */
.quiz__feedback {
  margin-top: 32rpx;
}

.quiz__feedback-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  animation: slideUp 0.3s ease;
}

.quiz__feedback-banner--correct {
  background: rgba(63, 185, 80, 0.12);
  border: 1rpx solid rgba(63, 185, 80, 0.3);
}

.quiz__feedback-banner--wrong {
  background: rgba(248, 81, 73, 0.12);
  border: 1rpx solid rgba(248, 81, 73, 0.3);
}

.quiz__feedback-emoji {
  font-size: 40rpx;
}

.quiz__feedback-text {
  font-size: 28rpx;
  color: #344054;
  line-height: 1.4;
}

/* ============================================
   Stage 4: Mastery Recall
   ============================================ */
.mastery__prompt {
  text-align: center;
  padding: 40rpx 0 32rpx;
}

.mastery__prompt-label {
  font-size: 28rpx;
  color: #667085;
  display: block;
  margin-bottom: 24rpx;
}

.mastery__chinese {
  background: #f8f9fc;
  border: 1rpx solid #edf0f6;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin: 0 20rpx;
}

.mastery__chinese-text {
  font-size: 34rpx;
  color: #1a1a2e;
  line-height: 1.6;
}

.mastery__reveal {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.mastery__answer {
  padding: 32rpx 0 0;
}

/* ============================================
   Stage 4: Word Select (Duolingo-style)
   ============================================ */
.mastery__word-select {
  padding: 8rpx 20rpx 0;
}

.mastery__ws-label {
  display: block;
  font-size: 26rpx;
  color: #667085;
  margin-bottom: 24rpx;
  text-align: center;
}

/* Answer slots */
.mastery__ws-slots {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  padding: 20rpx 0;
  min-height: 96rpx;
}

.mastery__ws-slot {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 80rpx;
  height: 80rpx;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  background: #f8f9fc;
  border: 2rpx dashed #d0d5dd;
  font-size: 30rpx;
  color: #1a1a2e;
  font-weight: 500;
  transition: all 0.2s ease;
}

.mastery__ws-slot--filled {
  background: rgba(102, 126, 234, 0.12);
  border: 2rpx solid rgba(102, 126, 234, 0.4);
  border-style: solid;
}

.mastery__ws-slot--correct {
  background: rgba(63, 185, 80, 0.15) !important;
  border: 2rpx solid rgba(63, 185, 80, 0.5) !important;
  border-style: solid !important;
  color: #2e7d32;
}

.mastery__ws-slot--wrong {
  background: rgba(248, 81, 73, 0.12) !important;
  border: 2rpx solid rgba(248, 81, 73, 0.4) !important;
  border-style: solid !important;
  color: #d92d20;
}

.mastery__ws-slot-placeholder {
  font-size: 36rpx;
  color: #c0c5d0;
  font-weight: 300;
}

/* Feedback */
.mastery__ws-feedback {
  padding: 16rpx 0 0;
  text-align: center;
}

.mastery__ws-feedback--show {
  animation: slideUp 0.3s ease;
}

.mastery__ws-feedback-text {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

/* Available word tiles */
.mastery__ws-tiles {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  padding: 24rpx 20rpx 0;
}

.mastery__ws-tile {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx solid #d0d5dd;
  font-size: 28rpx;
  color: #344054;
  font-weight: 500;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx rgba(16, 24, 40, 0.06);
}

.mastery__ws-tile:active {
  transform: scale(0.95);
  background: rgba(102, 126, 234, 0.08);
  border-color: #667eea;
}

.mastery__ws-tile--used {
  opacity: 0.25;
  pointer-events: none;
  background: #f0f2f5;
  border-color: transparent;
}

.mastery__answer-card {
  text-align: center;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(118, 75, 162, 0.15));
  border: 1rpx solid rgba(102, 126, 234, 0.3);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin: 0 20rpx 32rpx;
}

.mastery__answer-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
}

.mastery__answer-phonetic {
  font-size: 28rpx;
  color: #667085;
  display: block;
  margin-top: 8rpx;
}

.mastery__answer-audio {
  margin-top: 16rpx;
}

.mastery__answer-audio text {
  font-size: 26rpx;
  color: #667eea;
}

.mastery__assess-label {
  text-align: center;
  padding: 20rpx 0 24rpx;
}

.mastery__assess-label text {
  font-size: 28rpx;
  color: #667085;
}

.mastery__assess-btns {
  display: flex;
  gap: 16rpx;
  padding: 0 20rpx;
}

.mastery__btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 8rpx;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.mastery__btn:active {
  transform: scale(0.95);
}

.mastery__btn--forgot {
  background: rgba(248, 81, 73, 0.1);
  border-color: rgba(248, 81, 73, 0.3);
}

.mastery__btn--fuzzy {
  background: rgba(210, 153, 34, 0.1);
  border-color: rgba(210, 153, 34, 0.3);
}

.mastery__btn--remembered {
  background: rgba(63, 185, 80, 0.1);
  border-color: rgba(63, 185, 80, 0.3);
}

.mastery__btn--solid {
  background: rgba(102, 126, 234, 0.1);
  border-color: rgba(102, 126, 234, 0.3);
}

.mastery__btn-emoji {
  font-size: 44rpx;
}

.mastery__btn-label {
  font-size: 24rpx;
  color: #344054;
  font-weight: 500;
}

/* ============================================
   Report
   ============================================ */
.report {
  padding: 40rpx 32rpx;
}

.report__header {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.report__title-emoji {
  font-size: 80rpx;
  display: block;
}

.report__title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-top: 16rpx;
}

.report__subtitle {
  font-size: 28rpx;
  color: #667085;
  display: block;
  margin-top: 8rpx;
}

.report__card {
  background: #ffffff;
  border: 1rpx solid #edf0f6;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(30, 41, 59, 0.06);
}

.report__card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 24rpx;
}

.report__stat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.report__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
}

.report__stat-icon {
  font-size: 36rpx;
}

.report__stat-label {
  font-size: 24rpx;
  color: #667085;
}

.report__stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* Distribution bars */
.report__dist {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.report__dist-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.report__dist-emoji {
  font-size: 28rpx;
  width: 40rpx;
  text-align: center;
}

.report__dist-label {
  font-size: 26rpx;
  color: #667085;
  width: 80rpx;
}

.report__dist-bar-wrap {
  flex: 1;
  height: 24rpx;
  background: #edf0f6;
  border-radius: 12rpx;
  overflow: hidden;
}

.report__dist-bar {
  height: 100%;
  border-radius: 12rpx;
  min-width: 4rpx;
  transition: width 0.6s ease;
}

.report__dist-bar--solid {
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.report__dist-bar--remembered {
  background: linear-gradient(90deg, #3fb950, #38f9d7);
}

.report__dist-bar--fuzzy {
  background: linear-gradient(90deg, #d29922, #e3b341);
}

.report__dist-bar--forgot {
  background: linear-gradient(90deg, #f85149, #da3633);
}

.report__dist-count {
  font-size: 26rpx;
  color: #344054;
  font-weight: 600;
  width: 40rpx;
  text-align: right;
}

.report__streak {
  text-align: center;
  padding: 24rpx 0;
}

.report__streak-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #f0883e;
}

.report__actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
}

/* ============================================
   Buttons
   ============================================ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 40rpx;
  border-radius: 20rpx;
  transition: all 0.2s ease;
  flex: 1;
}

.btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn--disabled {
  opacity: 0.4;
  pointer-events: none;
}

.btn__text {
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.btn-primary .btn__text {
  color: #ffffff;
}

.btn-next {
  background: rgba(102, 126, 234, 0.15);
  border: 2rpx solid rgba(102, 126, 234, 0.4);
}

.btn-next .btn__text {
  color: #667eea;
}

.btn-flip {
  background: #ffffff;
  border: 2rpx solid #dfe4f2;
  padding: 32rpx 60rpx;
  box-shadow: 0 10rpx 28rpx rgba(30, 41, 59, 0.06);
}

.btn-flip .btn__text {
  color: #667eea;
  font-size: 32rpx;
}

.btn-share {
  background: #ffffff;
  border: 2rpx solid #dfe4f2;
}

.btn-share .btn__text {
  color: #667085;
}

.stage-action {
  padding: 40rpx 0 20rpx;
}

/* ============================================
   Animations
   ============================================ */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes flipIn {
  from { opacity: 0; transform: rotateX(90deg); }
  to   { opacity: 1; transform: rotateX(0); }
}

.animate-fade-in {
  animation: fadeIn 0.35s ease-out;
}

.animate-flip-in {
  animation: flipIn 0.4s ease-out;
}
