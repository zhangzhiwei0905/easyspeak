/**
 * EasySpeak — Immersive Learning Session Styles
 * Full-screen, light-themed immersive design
 */

/* ============================================
   Page & Layout
   ============================================ */
.learn-page {
  min-height: 100vh;
  background: var(--color-bg);
  color: var(--color-text-primary);
  padding-top: 0;
  box-sizing: border-box;
}

/* ============================================
   Custom Navigation Bar
   ============================================ */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 32rpx 24rpx;
  position: relative;
  z-index: 10;
}

.nav-bar__left {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s, transform 0.15s ease;
}

.nav-bar__left:active {
  background: var(--color-bg);
  transform: scale(0.93);
}

.nav-bar__close {
  font-size: 40rpx;
  color: var(--color-text-secondary);
  font-weight: 300;
}

.nav-bar__center {
  flex: 1;
  text-align: center;
}

.nav-bar__title {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  letter-spacing: 2rpx;
}

.nav-bar__right {
  width: 80rpx;
}

/* ============================================
   Loading & Error States
   ============================================ */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 0 32rpx;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.loading-dots__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-primary);
  animation: dotBounce 1.2s ease-in-out infinite;
}

.loading-dots__dot:nth-child(2) {
  animation-delay: 0.15s;
}

.loading-dots__dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-state__title {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  margin-bottom: 22rpx;
}

.loading-progress {
  width: 72%;
  max-width: 520rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.loading-progress__track {
  flex: 1;
  height: 14rpx;
  background: var(--color-border);
  border-radius: 999rpx;
  overflow: hidden;
}

.loading-progress__fill {
  height: 100%;
  border-radius: 999rpx;
  background: var(--color-primary-gradient);
  transition: width 0.24s ease;
  position: relative;
  overflow: hidden;
}

.loading-progress__fill::after {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  width: 96rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.65), transparent);
  animation: progressShimmer 1.1s ease-in-out infinite;
}

@keyframes progressShimmer {
  from { transform: translateX(-110rpx); }
  to { transform: translateX(560rpx); }
}

.loading-progress__value {
  width: 72rpx;
  text-align: right;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  font-variant-numeric: tabular-nums;
}

.loading-state__text {
  font-size: 24rpx;
  color: var(--color-text-hint);
  text-align: center;
  line-height: 1.5;
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 250rpx;
  gap: 24rpx;
}

.error-state__icon {
  font-size: 80rpx;
}

.error-state__text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

/* ============================================
   Progress Strip
   ============================================ */
.progress-strip {
  padding: 0 32rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-strip__track {
  flex: 1;
  height: 8rpx;
  background: var(--color-bg);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-strip__fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.4s ease;
}

.progress-strip__fill--s1 {
  background: var(--color-primary-gradient);
}

.progress-strip__fill--s2 {
  background: linear-gradient(90deg, var(--color-primary), var(--color-error));
}

.progress-strip__fill--s3 {
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary));
}

.progress-strip__fill--s4 {
  background: linear-gradient(90deg, var(--color-success), var(--color-success));
}

.progress-strip__text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  white-space: nowrap;
}

/* ============================================
   Stage Card (shared container)
   ============================================ */
.stage-card {
  margin: 0 32rpx;
  padding: 40rpx 32rpx;
  background: var(--color-card);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(16, 24, 40, 0.08);
}

/* ============================================
   Stage 1: Exposure
   ============================================ */
.exposure__main-text {
  text-align: center;
  padding: 40rpx 0 8rpx;
}

.exposure__phrase {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.exposure__word {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.exposure__phonetic {
  display: block;
  margin-top: 12rpx;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 400;
}

.exposure__audio {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0 32rpx;
  transition: opacity 0.15s ease, transform 0.15s ease;
}

.exposure__audio:active {
  opacity: 0.6;
  transform: scale(0.96);
}

.exposure__audio-icon {
  font-size: 36rpx;
}

.exposure__audio-label {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.exposure__card {
  background: var(--color-bg);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 12rpx;
}

.exposure__pos {
  margin-bottom: 16rpx;
}

.exposure__pos-tag {
  display: inline-block;
  background: rgba(0, 122, 255, 0.1);
  color: var(--color-primary);
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.exposure__meaning-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.exposure__meaning-label {
  font-size: 28rpx;
  flex-shrink: 0;
}

.exposure__meaning-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.exposure__example {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.exposure__example-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.exposure__example-en {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-style: italic;
  line-height: 1.5;
}

.exposure__example-cn {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.exposure__source {
  margin-top: 16rpx;
}

.exposure__source-text {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.exposure__usage {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.exposure__usage-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 10rpx;
}

.exposure__usage-note {
  display: block;
  font-size: 27rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.exposure__context-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.exposure__context-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.exposure__context-tag {
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  background: rgba(0, 122, 255, 0.1);
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.exposure__context-copy {
  flex: 1;
}

.exposure__context-meaning {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.45;
}

.exposure__context-example {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.45;
  font-style: italic;
}

/* ============================================
   Stage 2 & 3: Quiz
   ============================================ */
.quiz__question {
  padding: 20rpx 0 40rpx;
}

.quiz__question-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
  display: block;
}

.quiz__hint {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-primary);
}

.quiz__options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.quiz__option {
  display: flex;
  align-items: center;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  transition: all 0.2s ease;
}

.quiz__option--selected {
  border-color: var(--color-primary);
  background: rgba(0, 122, 255, 0.1);
}

.quiz__option--correct {
  border-color: var(--color-success) !important;
  background: rgba(63, 185, 80, 0.12) !important;
}

.quiz__option--wrong {
  border-color: var(--color-error) !important;
  background: rgba(248, 81, 73, 0.12) !important;
}

.quiz__option-key {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--color-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.quiz__option--selected .quiz__option-key {
  background: var(--color-primary);
  color: #ffffff;
}

.quiz__option--correct .quiz__option-key {
  background: var(--color-success);
  color: #ffffff;
}

.quiz__option--wrong .quiz__option-key {
  background: var(--color-error);
  color: #ffffff;
}

.quiz__option-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.quiz__option-icon {
  font-size: 32rpx;
  color: var(--color-success);
  margin-left: 12rpx;
  font-weight: 700;
}

.quiz__option-icon--wrong {
  color: var(--color-error);
}

/* Quiz Feedback */
.quiz__feedback {
  margin-top: 32rpx;
}

.quiz__feedback-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  animation: slideUp 0.3s ease;
}

.quiz__feedback-banner--correct {
  background: rgba(63, 185, 80, 0.12);
  border: 1rpx solid rgba(63, 185, 80, 0.3);
}

.quiz__feedback-banner--wrong {
  background: rgba(248, 81, 73, 0.12);
  border: 1rpx solid rgba(248, 81, 73, 0.3);
}

.quiz__feedback-emoji {
  font-size: 40rpx;
}

.quiz__feedback-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.4;
}

/* ============================================
   Stage 4: Mastery Recall
   ============================================ */
.mastery__prompt {
  text-align: center;
  padding: 40rpx 0 32rpx;
}

.mastery__prompt-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 24rpx;
}

.mastery__chinese {
  background: var(--color-bg);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin: 0 20rpx;
}

.mastery__chinese-text {
  font-size: 34rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.mastery__reveal {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.mastery__answer {
  padding: 32rpx 0 0;
}

/* ============================================
   Stage 4: Word Select (Duolingo-style)
   ============================================ */
.mastery__word-select {
  padding: 8rpx 20rpx 0;
}

.mastery__ws-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
  text-align: center;
}

/* Answer slots */
.mastery__ws-slots {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  padding: 20rpx 0;
  min-height: 96rpx;
}

.mastery__ws-slot {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 80rpx;
  height: 80rpx;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  background: var(--color-bg);
  border: 2rpx dashed var(--color-border);
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  transition: all 0.2s ease;
}

.mastery__ws-slot--filled {
  background: rgba(0, 122, 255, 0.12);
  border: 2rpx solid rgba(0, 122, 255, 0.4);
  border-style: solid;
}

.mastery__ws-slot--correct {
  background: rgba(63, 185, 80, 0.15) !important;
  border: 2rpx solid rgba(63, 185, 80, 0.5) !important;
  border-style: solid !important;
  color: var(--color-success);
}

.mastery__ws-slot--wrong {
  background: rgba(248, 81, 73, 0.12) !important;
  border: 2rpx solid rgba(248, 81, 73, 0.4) !important;
  border-style: solid !important;
  color: var(--color-error);
}

.mastery__ws-slot-placeholder {
  font-size: 36rpx;
  color: var(--color-text-hint);
  font-weight: 300;
}

/* Feedback */
.mastery__ws-feedback {
  padding: 16rpx 0 0;
  text-align: center;
}

.mastery__ws-feedback--show {
  animation: slideUp 0.3s ease;
}

.mastery__ws-feedback-text {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* Available word tiles */
.mastery__ws-tiles {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  padding: 24rpx 20rpx 0;
}

.mastery__ws-tile {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  border-radius: 16rpx;
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx rgba(16, 24, 40, 0.06);
}

.mastery__ws-tile:active {
  transform: scale(0.95);
  background: rgba(0, 122, 255, 0.08);
  border-color: var(--color-primary);
}

.mastery__ws-tile--used {
  opacity: 0.25;
  pointer-events: none;
  background: var(--color-bg);
  border-color: transparent;
}

.mastery__answer-card {
  text-align: center;
  background: linear-gradient(135deg, rgba(0, 122, 255, 0.15), rgba(88, 86, 214, 0.15));
  border: 1rpx solid rgba(0, 122, 255, 0.3);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin: 0 20rpx 32rpx;
}

.mastery__answer-text {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
}

.mastery__answer-phonetic {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 8rpx;
}

.mastery__answer-audio {
  margin-top: 16rpx;
}

.mastery__answer-audio text {
  font-size: 26rpx;
  color: var(--color-primary);
}

.mastery__assess-label {
  text-align: center;
  padding: 20rpx 0 24rpx;
}

.mastery__assess-label text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.mastery__assess-btns {
  display: flex;
  gap: 16rpx;
  padding: 0 20rpx;
}

.mastery__btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 8rpx;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.mastery__btn:active {
  transform: scale(0.95);
}

.mastery__btn--forgot {
  background: rgba(248, 81, 73, 0.1);
  border-color: rgba(248, 81, 73, 0.3);
}

.mastery__btn--fuzzy {
  background: rgba(210, 153, 34, 0.1);
  border-color: rgba(210, 153, 34, 0.3);
}

.mastery__btn--remembered {
  background: rgba(63, 185, 80, 0.1);
  border-color: rgba(63, 185, 80, 0.3);
}

.mastery__btn--solid {
  background: rgba(0, 122, 255, 0.1);
  border-color: rgba(0, 122, 255, 0.3);
}

.mastery__btn-emoji {
  font-size: 44rpx;
}

.mastery__btn-label {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

/* ============================================
   Report
   ============================================ */
.report {
  padding: 40rpx 32rpx;
}

.report__header {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.report__title-emoji {
  font-size: 80rpx;
  display: block;
}

.report__title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
  margin-top: 16rpx;
}

.report__subtitle {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 8rpx;
}

.report__card {
  background: var(--color-card);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(30, 41, 59, 0.06);
}

.report__card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 24rpx;
}

.report__stat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.report__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
}

.report__stat-icon {
  font-size: 36rpx;
}

.report__stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.report__stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

/* Distribution bars */
.report__dist {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.report__dist-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.report__dist-emoji {
  font-size: 28rpx;
  width: 40rpx;
  text-align: center;
}

.report__dist-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  width: 80rpx;
}

.report__dist-bar-wrap {
  flex: 1;
  height: 24rpx;
  background: var(--color-border);
  border-radius: 12rpx;
  overflow: hidden;
}

.report__dist-bar {
  height: 100%;
  border-radius: 12rpx;
  min-width: 4rpx;
  transition: width 0.6s ease;
}

.report__dist-bar--solid {
  background: var(--color-primary-gradient);
}

.report__dist-bar--remembered {
  background: linear-gradient(90deg, var(--color-success), var(--color-success));
}

.report__dist-bar--fuzzy {
  background: linear-gradient(90deg, var(--color-warning), var(--color-warning));
}

.report__dist-bar--forgot {
  background: linear-gradient(90deg, var(--color-error), var(--color-error));
}

.report__dist-count {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  width: 40rpx;
  text-align: right;
}

.report__streak {
  text-align: center;
  padding: 24rpx 0;
}

.report__streak-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-warning);
}

.report__actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
}

/* ============================================
   Buttons
   ============================================ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 40rpx;
  border-radius: 20rpx;
  transition: all 0.2s ease;
  flex: 1;
}

.btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn--disabled {
  opacity: 0.4;
  pointer-events: none;
}

.btn__text {
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary {
  background: var(--color-primary-gradient);
}

.btn-primary .btn__text {
  color: #ffffff;
}

.btn-next {
  background: rgba(0, 122, 255, 0.15);
  border: 2rpx solid rgba(0, 122, 255, 0.4);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.btn-next:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0, 122, 255, 0.15);
}

.btn-next .btn__text {
  color: var(--color-primary);
}

.btn-flip {
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  padding: 32rpx 60rpx;
  box-shadow: 0 10rpx 28rpx rgba(30, 41, 59, 0.06);
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}

.btn-flip:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(30, 41, 59, 0.1);
}

.btn-flip .btn__text {
  color: var(--color-primary);
  font-size: 32rpx;
}

.btn-share {
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  transition: transform 0.15s ease, background 0.2s;
}

.btn-share:active {
  transform: scale(0.97);
  background: var(--color-bg);
}

.btn-share .btn__text {
  color: var(--color-text-secondary);
}

.stage-action {
  padding: 40rpx 0 20rpx;
}

/* ============================================
   Animations
   ============================================ */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes flipIn {
  from { opacity: 0; transform: rotateX(90deg); }
  to   { opacity: 1; transform: rotateX(0); }
}

.animate-fade-in {
  animation: fadeIn 0.35s ease-out;
}

.animate-flip-in {
  animation: flipIn 0.4s ease-out;
}
