<!-- EasySpeak Library Page (内容库) -->
<view class="page library-page">

  <!-- ========== Search Area ========== -->
  <view class="search-area">
    <view class="search-bar {{(searchActive || searchKeyword) ? 'search-bar--active' : ''}}">
      <view class="search-bar__inner">
        <text class="search-bar__icon">🔍</text>
        <input class="search-bar__input"
               placeholder="搜索短语/单词/主题..."
               placeholder-class="search-bar__placeholder"
               value="{{searchKeyword}}"
               focus="{{searchFocused}}"
               bindfocus="onSearchFocus"
               bindblur="onSearchBlur"
               bindinput="onSearchInput"
               bindconfirm="onSearchConfirm"
               confirm-type="search" />
        <text class="search-bar__clear" wx:if="{{searchKeyword}}" catchtap="onSearchClear">✕</text>
      </view>
      <text class="search-bar__cancel" wx:if="{{searchActive || searchKeyword}}" catchtap="onSearchCancel">取消</text>
    </view>

    <!-- Search Overlay: history + results -->
    <block wx:if="{{searchActive || searchKeyword}}">
      <!-- History Panel (when focused but no keyword) -->
      <view class="search-panel" wx:if="{{searchActive && !searchKeyword && searchHistory.length > 0}}">
        <view class="search-panel__header">
          <text class="search-panel__title">搜索历史</text>
          <text class="search-panel__clear" catchtap="onClearHistory">清空</text>
        </view>
        <view class="search-panel__tags">
          <view class="search-panel__tag"
                wx:for="{{searchHistory}}"
                wx:key="index"
                data-keyword="{{item}}"
                catchtap="onHistoryTap">
            <text>{{item}}</text>
          </view>
        </view>
      </view>

      <!-- Search Results (when keyword exists) -->
      <view class="search-results" wx:if="{{searchKeyword && searchDone}}">
        <view class="search-results__empty" wx:if="{{searchThemes.length === 0 && searchPhrases.length === 0 && searchWords.length === 0}}">
          <text class="search-results__empty-text">没有找到 "{{searchKeyword}}" 相关的内容</text>
        </view>

        <!-- Theme Results -->
        <view class="search-results__group" wx:if="{{searchThemes.length > 0}}">
          <text class="search-results__group-title">🏷️ 相关主题</text>
          <view class="search-results__item"
                wx:for="{{searchThemes}}"
                wx:key="id"
                data-id="{{item.contentId}}"
                catchtap="onSearchResultTap">
            <view class="search-results__item-main">
              <text class="search-results__item-text">{{item.themeZh}}</text>
              <text class="search-results__item-meaning" wx:if="{{item.themeEn}}">{{item.themeEn}}</text>
            </view>
            <view class="search-results__item-meta">
              <text>{{item.date}}</text>
            </view>
          </view>
        </view>

        <!-- Phrase Results -->
        <view class="search-results__group" wx:if="{{searchPhrases.length > 0}}">
          <text class="search-results__group-title">💬 相关短语</text>
          <view class="search-results__item"
                wx:for="{{searchPhrases}}"
                wx:key="id"
                data-id="{{item.contentId}}"
                data-target-id="{{item.id}}"
                data-type="phrase"
                catchtap="onSearchResultTap">
            <view class="search-results__item-main">
              <text class="search-results__item-text">{{item.phrase}}</text>
              <text class="search-results__item-meaning" wx:if="{{item.meaning}}">{{item.meaning}}</text>
            </view>
            <view class="search-results__item-meta">
              <text>{{item.theme}} · {{item.date}}</text>
            </view>
          </view>
        </view>

        <!-- Word Results -->
        <view class="search-results__group" wx:if="{{searchWords.length > 0}}">
          <text class="search-results__group-title">📚 相关单词</text>
          <view class="search-results__item"
                wx:for="{{searchWords}}"
                wx:key="id"
                data-id="{{item.contentId}}"
                data-target-id="{{item.id}}"
                data-type="word"
                catchtap="onSearchResultTap">
            <view class="search-results__item-main">
              <text class="search-results__item-text">{{item.word}}</text>
              <text class="search-results__item-meaning" wx:if="{{item.meaning}}">{{item.meaning}}</text>
            </view>
            <view class="search-results__item-meta">
              <text>{{item.theme}} · {{item.date}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Searching... -->
      <view class="search-results" wx:if="{{searchKeyword && !searchDone}}">
        <view class="search-results__loading">
          <view class="load-more__spinner"></view>
          <text class="search-results__loading-text">搜索中...</text>
        </view>
      </view>
    </block>
  </view>

  <scroll-view class="category-filter" scroll-x="true" show-scrollbar="false" wx:if="{{!searchActive && !searchKeyword}}">
    <view class="category-filter__inner">
      <view class="category-filter__chip {{selectedCategory === item.key ? 'category-filter__chip--active' : ''}}"
            wx:for="{{categoryFilters}}"
            wx:key="key"
            data-category="{{item.key}}"
            bindtap="onCategoryTap">
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- ========== Loading Skeleton ========== -->
  <view class="skeleton" wx:if="{{loading}}">
    <view class="skeleton__card" wx:for="{{3}}" wx:key="index">
      <view class="skeleton__card-header">
        <view class="skeleton__line skeleton__line--title"></view>
        <view class="skeleton__line skeleton__line--short" style="margin-bottom:0"></view>
      </view>
      <view class="skeleton__line skeleton__line--body"></view>
    </view>
  </view>

  <!-- ========== Error State ========== -->
  <view class="error-state" wx:if="{{error && !loading}}">
    <text class="error-state__icon">😞</text>
    <text class="error-state__text">{{errorMsg || '加载失败，请重试'}}</text>
    <button class="btn btn-primary btn-sm mt-lg" bindtap="onRetry">重新加载</button>
  </view>

  <!-- ========== Empty State ========== -->
  <view class="empty-state" wx:if="{{isEmpty && !loading && !error}}">
    <text class="empty-state__icon">📚</text>
    <text class="empty-state__title">暂无内容</text>
    <text class="empty-state__desc">还没有推送内容哦</text>
  </view>

  <!-- ========== Content List ========== -->
  <block wx:if="{{!loading && !error && !isEmpty && !searchActive && !searchKeyword}}">

    <!-- Date Groups -->
    <view class="date-group" wx:for="{{dateGroups}}" wx:key="date">
      <!-- Date Header -->
      <view class="date-group__header">
        <view class="date-group__line"></view>
        <text class="date-group__label">{{item.label}}</text>
        <view class="date-group__line"></view>
      </view>

      <!-- Content Cards -->
      <view class="content-card card animate-fade-in"
            wx:for="{{item.items}}"
            wx:for-item="content"
            wx:key="id"
            data-id="{{content.id}}"
            bindtap="onContentTap">
        <view class="content-card__header">
          <text class="content-card__icon">📖</text>
          <view class="content-card__theme">
            <text class="content-card__theme-zh">{{content.themeZh}}</text>
            <text class="content-card__theme-en">{{content.themeEn}}</text>
            <text class="content-card__category" wx:if="{{content.categoryZh}}">{{content.categoryZh}}</text>
          </view>
          <view class="content-card__arrow">
            <text class="content-card__arrow-icon">›</text>
          </view>
        </view>
        <view class="content-card__footer">
          <view class="content-card__stats">
            <text class="content-card__stat">📝 {{content.phraseCount}}个短语</text>
            <text class="content-card__stat-divider">·</text>
            <text class="content-card__stat">📚 {{content.wordCount}}个单词</text>
          </view>
          <view class="content-card__mastery" wx:if="{{content.studied}}">
            <text class="content-card__mastery-icon">✅</text>
            <text class="content-card__mastery-text">已学</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Load More Indicator -->
    <view class="load-more" wx:if="{{loadingMore}}">
      <view class="load-more__spinner"></view>
      <text class="load-more__text">加载中...</text>
    </view>

    <!-- No More Data -->
    <view class="load-more" wx:if="{{!hasMore && dateGroups.length > 0}}">
      <text class="load-more__text load-more__text--end">— 没有更多内容了 —</text>
    </view>

  </block>

  <!-- Bottom safe area -->
  <view class="safe-bottom" style="height: 40rpx;"></view>
</view>
