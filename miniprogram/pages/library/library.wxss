/* ========================================
   Library Page Styles
   ======================================== */

/* ---------- Search Area ---------- */
.search-area {
  position: relative;
  z-index: 100;
  padding-bottom: var(--spacing-md);
}

.search-bar {
  display: flex;
  align-items: center;
  transition: all 0.25s ease;
}

.search-bar__inner {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-round);
  padding: 18rpx var(--spacing-card);
  box-shadow: var(--shadow-card);
  transition: all 0.25s ease;
  border: 2rpx solid transparent;
}

.search-bar--active .search-bar__inner {
  border-color: rgba(102, 126, 234, 0.4);
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.15);
}

.search-bar__cancel {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  padding: 0 0 0 var(--spacing-md);
  white-space: nowrap;
  transition: all 0.25s ease;
}

.search-bar__cancel:active {
  color: var(--color-primary);
}

.search-bar__icon {
  font-size: 28rpx;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.search-bar__input {
  flex: 1;
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  min-height: 40rpx;
}

.search-bar__placeholder {
  color: var(--color-text-hint);
}

.search-bar__clear {
  font-size: 28rpx;
  color: #bbb;
  padding: 8rpx 12rpx;
  flex-shrink: 0;
}

.search-bar__clear:active {
  color: #888;
}

/* Removed Backdrop */

/* ---------- Search History Panel ---------- */
.search-panel {
  position: relative;
  z-index: 100;
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 24rpx var(--spacing-card);
  margin-top: var(--spacing-sm);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  animation: panelSlideIn 0.2s ease;
}

@keyframes panelSlideIn {
  from { opacity: 0; transform: translateY(-12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.search-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.search-panel__title {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.search-panel__clear {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
  padding: 8rpx 16rpx;
}

.search-panel__clear:active {
  color: #ff4d4f;
}

.search-panel__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.search-panel__tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  background: #f5f6fa;
  border-radius: var(--radius-round);
  font-size: var(--font-size-small);
  color: var(--color-text-secondary);
  transition: background 0.2s;
}

.search-panel__tag:active {
  background: #e8e9ed;
}

/* ---------- Search Results ---------- */
.category-filter {
  white-space: nowrap;
  margin: -6rpx 0 var(--spacing-md);
}

.category-filter__inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 4rpx 4rpx;
}

.category-filter__chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-round);
  background: #ffffff;
  border: 1rpx solid var(--color-border);
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.category-filter__chip--active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-color: transparent;
  color: #ffffff;
  font-weight: 600;
}

/* ---------- Search Results ---------- */
.search-results {
  position: relative;
  z-index: 100;
  margin-top: var(--spacing-sm);
  animation: panelSlideIn 0.2s ease;
}

.search-results__loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  gap: 16rpx;
}

.search-results__loading-text {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

.search-results__empty {
  text-align: center;
  padding: 60rpx 0;
}

.search-results__empty-text {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

.search-results__group {
  margin-bottom: 24rpx;
}

.search-results__group-title {
  display: block;
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  font-weight: 600;
  margin-bottom: 16rpx;
}

.search-results__item {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 24rpx var(--spacing-card);
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-card);
  transition: background 0.15s;
}

.search-results__item:active {
  background: #f8f9fc;
}

.search-results__item-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.search-results__item-text {
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.search-results__item-meaning {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-results__item-meta {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
}

/* ---------- Skeleton ---------- */
.library-page .skeleton {
  padding: 0;
}

.library-page .skeleton__card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-md);
}

.library-page .skeleton__card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.library-page .skeleton__line {
  height: 28rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 400% 100%;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  animation: shimmer 1.5s ease-in-out infinite;
}

.library-page .skeleton__line--short { width: 30%; margin-bottom: 0; }
.library-page .skeleton__line--title { width: 55%; height: 32rpx; margin-bottom: 0; }
.library-page .skeleton__line--body  { width: 80%; margin-bottom: 0; }

/* ---------- Error State ---------- */
.library-page .error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx var(--spacing-page);
}

.library-page .error-state__icon { font-size: 120rpx; margin-bottom: var(--spacing-lg); }
.library-page .error-state__text { font-size: var(--font-size-body); color: var(--color-text-secondary); text-align: center; }

/* ---------- Empty State ---------- */
.library-page .empty-state__icon   { font-size: 120rpx; margin-bottom: var(--spacing-lg); }
.library-page .empty-state__title  { font-size: var(--font-size-title); font-weight: 600; color: var(--color-text-primary); margin-bottom: var(--spacing-sm); }
.library-page .empty-state__desc   { font-size: var(--font-size-caption); color: var(--color-text-secondary); }

/* ---------- Date Group ---------- */
.date-group { margin-bottom: var(--spacing-md); }

.date-group__header {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) 0;
  margin-bottom: var(--spacing-sm);
}

.date-group__line { flex: 1; height: 1rpx; background: var(--color-border); }

.date-group__label {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  padding: 0 var(--spacing-md);
  white-space: nowrap;
  font-weight: 500;
}

/* ---------- Content Card ---------- */
.content-card {
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-md);
  transition: box-shadow 0.2s, transform 0.2s;
}

.content-card:active {
  box-shadow: var(--shadow-card-hover);
  transform: scale(0.99);
}

.content-card__header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.content-card__icon {
  font-size: 44rpx;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.content-card__theme {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.content-card__theme-zh {
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.content-card__theme-en {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  line-height: 1.4;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.content-card__category {
  display: inline-flex;
  align-self: flex-start;
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-round);
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  font-size: 22rpx;
}

.content-card__arrow {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: var(--spacing-xs);
}

.content-card__arrow-icon {
  font-size: 40rpx;
  color: var(--color-text-hint);
  font-weight: 300;
}

.content-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.content-card__stats {
  display: flex;
  align-items: center;
}

.content-card__stat {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
}

.content-card__stat-divider {
  margin: 0 12rpx;
  color: var(--color-border);
  font-size: var(--font-size-small);
}

.content-card__mastery {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.content-card__mastery-icon { font-size: 24rpx; }

.content-card__mastery-text {
  font-size: var(--font-size-small);
  color: var(--color-success);
  font-weight: 500;
}

/* ---------- Load More ---------- */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg) 0;
  gap: 12rpx;
}

.load-more__spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.load-more__text {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

.load-more__text--end {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
}

/* ---------- Shimmer Animation ---------- */
@keyframes shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
