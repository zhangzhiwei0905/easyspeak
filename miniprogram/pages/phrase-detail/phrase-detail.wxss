/* ========================================
   Phrase Detail Page Styles
   ======================================== */

/* ---------- Skeleton ---------- */
.phrase-detail-page .skeleton__phrase-card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-lg) var(--spacing-card);
  margin-bottom: var(--spacing-lg);
}

.phrase-detail-page .skeleton__example-card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-md);
}

.phrase-detail-page .skeleton__line {
  height: 28rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 400% 100%;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  animation: shimmer 1.5s ease-in-out infinite;
}

.phrase-detail-page .skeleton__line--phrase {
  width: 70%;
  height: 48rpx;
  margin-bottom: 28rpx;
}

.phrase-detail-page .skeleton__line--short {
  width: 30%;
  margin-bottom: 16rpx;
}

.phrase-detail-page .skeleton__line--medium {
  width: 60%;
  margin-bottom: 0;
}

.phrase-detail-page .skeleton__line--body {
  width: 90%;
}

.phrase-detail-page .skeleton__line--long {
  width: 95%;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ---------- Error State ---------- */
.error-state__actions {
  display: flex;
  align-items: center;
  margin-top: var(--spacing-lg);
}

/* ---------- Phrase Hero Card ---------- */
.phrase-hero-card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-lg) var(--spacing-card);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-card);
  position: relative;
  overflow: hidden;
}

.phrase-hero-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 50%, #e8590c 100%);
}

.phrase-hero-card__meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: var(--spacing-md);
}

.phrase-hero-card__theme {
  font-size: var(--font-size-caption);
  color: var(--color-primary);
  background: rgba(102, 126, 234, 0.1);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
}

.phrase-hero-card__date {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
}

.phrase-hero-card__phrase {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
  margin-bottom: var(--spacing-lg);
  letter-spacing: 1rpx;
}

.phrase-hero-card__explanation {
  margin-bottom: var(--spacing-md);
}

.phrase-hero-card__label {
  display: block;
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.phrase-hero-card__text {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.phrase-hero-card__source {
  display: inline-flex;
  align-items: center;
  background: rgba(232, 89, 12, 0.08);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-round);
  margin-top: var(--spacing-sm);
}

.phrase-hero-card__source-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.phrase-hero-card__source-text {
  font-size: var(--font-size-caption);
  color: var(--color-accent);
  font-weight: 500;
}

/* ---------- Section Label ---------- */
.section-label {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
  padding-left: 8rpx;
}

.section-label__icon {
  font-size: 30rpx;
  margin-right: 8rpx;
}

.section-label__text {
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

/* ---------- Examples Section ---------- */
.examples-section {
  margin-bottom: var(--spacing-lg);
}

.example-card {
  padding: var(--spacing-card);
}

.example-card__header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.example-card__num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-primary-gradient);
  color: #ffffff;
  font-size: var(--font-size-small);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.example-card__tag {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-primary);
  background: rgba(102, 126, 234, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  letter-spacing: 1rpx;
}

.example-card__en {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  line-height: 1.7;
  font-weight: 500;
}

.example-card__divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 16rpx 0;
}

.example-card__cn-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.example-card__tag--cn {
  color: var(--color-accent);
  background: rgba(232, 89, 12, 0.1);
  flex-shrink: 0;
  margin-top: 2rpx;
}

.example-card__cn {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* ---------- Mastery Section ---------- */
.mastery-section {
  margin-bottom: var(--spacing-lg);
}

.mastery-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-card);
}

.mastery-card__stars {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: var(--spacing-sm);
}

.mastery-star {
  padding: 8rpx;
  transition: transform 0.2s ease;
}

.mastery-star:active {
  transform: scale(0.85);
}

.mastery-star__icon {
  font-size: 64rpx;
  color: #e0e0e0;
  transition: color 0.2s ease;
}

.mastery-star--active .mastery-star__icon {
  color: #faad14;
}

.mastery-card__label {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

/* ---------- Login Prompt ---------- */
.login-prompt {
  text-align: center;
  padding: var(--spacing-md) 0;
  margin-bottom: var(--spacing-lg);
}

.login-prompt__text {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

/* ---------- Share Section ---------- */
.share-section {
  margin-bottom: var(--spacing-lg);
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-round);
  border: 2rpx solid var(--color-primary);
  background: transparent;
  color: var(--color-primary);
  font-size: var(--font-size-body);
  font-weight: 500;
  transition: all 0.2s ease;
}

.share-btn::after {
  border: none;
}

.share-btn:active {
  background: rgba(102, 126, 234, 0.08);
  transform: scale(0.98);
}

.share-btn__icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.share-btn__text {
  font-size: var(--font-size-body);
  color: var(--color-primary);
}