/* pages/profile/profile.wxss */

/* User Info Header */
.profile-header {
  display: flex;
  align-items: center;
  padding: 48rpx 0 32rpx;
  margin-bottom: var(--spacing-lg);
}

.avatar-wrap {
  position: relative;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid var(--color-primary);
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}

.avatar-badge {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  width: 40rpx;
  height: 40rpx;
  background: var(--color-card);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
}

.user-desc {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  margin-top: 8rpx;
}

/* Stats Card */
.section-title-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
}

.stat-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.stat-item-wide {
  width: 100%;
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
  margin-top: 4rpx;
}

.accuracy-bar {
  width: 200rpx;
  height: 12rpx;
  background: var(--color-border);
  border-radius: var(--radius-round);
  overflow: hidden;
  margin-top: 12rpx;
}

.accuracy-bar-fill {
  height: 100%;
  background: var(--color-primary-gradient);
  border-radius: var(--radius-round);
  transition: width 0.6s ease;
}

/* Achievement Badges */
.achievement-count {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  margin-left: auto;
}

.achievement-categories {
  display: flex;
  flex-direction: column;
}

.achievement-category {
  margin-bottom: 24rpx;
}

.category-title {
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid var(--color-primary);
}

.badges-grid {
  display: flex;
  flex-wrap: wrap;
}

.badge-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  box-sizing: border-box;
}

.badge-icon-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.badge-unlocked .badge-icon-wrap {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(118, 75, 162, 0.15));
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
}

.badge-locked .badge-icon-wrap {
  background: var(--color-border);
  opacity: 0.5;
}

.badge-icon {
  font-size: 40rpx;
}

.badge-check {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-locked .badge-icon {
  filter: grayscale(100%);
  opacity: 0.5;
}

.badge-name {
  font-size: var(--font-size-caption);
  color: var(--color-text-primary);
  font-weight: 500;
  text-align: center;
}

.badge-locked .badge-name {
  color: var(--color-text-hint);
}

.badge-desc {
  font-size: 20rpx;
  color: var(--color-text-hint);
  margin-top: 2rpx;
  text-align: center;
}

.badge-date {
  font-size: 18rpx;
  color: var(--color-primary);
  margin-top: 2rpx;
}

/* Settings Preview */
.settings-preview {
  cursor: pointer;
}

.settings-preview:active {
  opacity: 0.8;
}

.settings-preview-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.settings-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.settings-label {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  font-weight: 500;
}

.arrow-icon {
  font-size: 36rpx;
  color: var(--color-text-hint);
  font-weight: 300;
}

/* Version Info */
.version-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
}

.version-text {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

.version-sub {
  font-size: 20rpx;
  color: var(--color-text-hint);
  margin-top: 8rpx;
  opacity: 0.7;
}
