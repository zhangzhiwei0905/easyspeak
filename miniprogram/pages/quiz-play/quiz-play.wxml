<view class="page quiz-play-page">
  <view class="quiz-play__nav">
    <view class="quiz-play__nav-back" bindtap="onBack">
      <text class="quiz-play__nav-back-text">‹</text>
    </view>
    <view class="quiz-play__nav-center">
      <text class="quiz-play__nav-title" wx:if="{{mode === 'wrong_review'}}">错题回顾</text>
      <text class="quiz-play__nav-title" wx:elif="{{mode === 'theme'}}">主题测验</text>
      <text class="quiz-play__nav-title" wx:else>闪电测验</text>
    </view>
    <view class="quiz-play__nav-right"></view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-state__spinner"></view>
    <text class="loading-state__text">正在生成题目...</text>
  </view>

  <view class="error-state" wx:if="{{loadError && !loading}}">
    <text class="error-state__icon">😞</text>
    <text class="error-state__text">{{errorMsg || '加载失败，请重试'}}</text>
    <view class="quiz-play__error-actions">
      <button class="btn btn-primary btn-block" bindtap="onRetry">重新加载</button>
      <button class="btn btn-outline btn-block mt-md" bindtap="onBack">返回</button>
    </view>
  </view>

  <block wx:if="{{!loading && !loadError && question}}">
    <view class="quiz-play__meta">
      <view class="quiz-play__progress">
        <view class="quiz-play__progress-header">
          <text class="quiz-play__progress-label">第 {{currentIndex + 1}} / {{totalQuestions}} 题</text>
          <text class="quiz-play__progress-correct" wx:if="{{correctCount > 0}}">✓ {{correctCount}}</text>
        </view>
        <progress-bar
          current="{{currentIndex + (submitted ? 1 : 0)}}"
          total="{{totalQuestions}}"
          color="#667eea"
          height="12">
        </progress-bar>
      </view>

      <view class="quiz-play__timer {{timerWarning ? 'quiz-play__timer--warning' : ''}}" wx:if="{{isTimed}}">
        <text class="quiz-play__timer-icon">⏱️</text>
        <text class="quiz-play__timer-text">{{timerDisplay}}</text>
      </view>
    </view>

    <view class="quiz-play__card card animate-fade-in">
      <view class="quiz-play__type-row">
        <text class="quiz-play__type-badge" wx:if="{{questionType === 'phrase_meaning_choice'}}">短语含义</text>
        <text class="quiz-play__type-badge" wx:elif="{{questionType === 'word_phonetic_choice'}}">单词音标</text>
        <text class="quiz-play__type-badge" wx:elif="{{questionType === 'phrase_fill_input'}}">短语填空</text>
        <text class="quiz-play__type-badge" wx:else>{{questionType}}</text>
      </view>

      <view class="quiz-play__question">
        <text class="quiz-play__question-text">{{prompt}}</text>
        <text class="quiz-play__question-hint" wx:if="{{question.hint}}">💡 提示：{{question.hint}}</text>
      </view>

      <view class="quiz-play__options" wx:if="{{interactionType === 'choice'}}">
        <view
          class="quiz-play__option {{selectedKey === item.key ? 'quiz-play__option--selected' : ''}} {{submitted && item.isAnswer ? 'quiz-play__option--correct' : ''}} {{submitted && selectedKey === item.key && !isCorrect ? 'quiz-play__option--wrong' : ''}}"
          wx:for="{{options}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="onSelectOption">
          <text class="quiz-play__option-key">{{item.key}}</text>
          <text class="quiz-play__option-text">{{item.text}}</text>
          <text class="quiz-play__option-icon" wx:if="{{submitted && item.isAnswer}}">✓</text>
          <text class="quiz-play__option-icon quiz-play__option-icon--wrong" wx:if="{{submitted && selectedKey === item.key && !isCorrect}}">✗</text>
        </view>
      </view>

      <!-- word_select: 多邻国风格短语选择 -->
      <view class="quiz-play__word-select" wx:if="{{interactionType === 'word_select'}}">
        <!-- 句子展示区（空白替换为选中词或占位） -->
        <view class="quiz-play__sentence">
          <text>{{prompt}}</text>
        </view>
        <!-- 候选词区 -->
        <view class="quiz-play__candidates">
          <view 
            class="quiz-play__chip {{selectedKey === item.key ? 'quiz-play__chip--selected' : ''}} {{submitted && item.isAnswer ? 'quiz-play__chip--correct' : ''}} {{submitted && selectedKey === item.key && !isCorrect ? 'quiz-play__chip--wrong' : ''}}"
            wx:for="{{options}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="onSelectOption">
            <text>{{item.text}}</text>
          </view>
        </view>
      </view>

      <view class="quiz-play__feedback" wx:if="{{submitted}}">
        <view class="quiz-play__feedback-banner {{isCorrect ? 'quiz-play__feedback-banner--correct' : 'quiz-play__feedback-banner--wrong'}}">
          <text class="quiz-play__feedback-emoji">{{isCorrect ? '🎉' : '😅'}}</text>
          <text class="quiz-play__feedback-text">{{isCorrect ? '太棒了！回答正确' : '答错了，正确答案是 ' + correctOptionText}}</text>
        </view>
      </view>
    </view>

    <view class="quiz-play__actions safe-bottom">
      <button
        class="btn btn-primary btn-block {{!canSubmit ? 'btn-disabled' : ''}}"
        wx:if="{{!submitted}}"
        bindtap="onSubmitAnswer">
        确认答案
      </button>

      <button
        class="btn btn-primary btn-block"
        wx:if="{{submitted && currentIndex < totalQuestions - 1}}"
        bindtap="onNextQuestion">
        下一题 →
      </button>

      <button
        class="btn btn-accent btn-block"
        wx:if="{{submitted && currentIndex >= totalQuestions - 1}}"
        bindtap="onNextQuestion">
        查看结果 📊
      </button>
    </view>
  </block>
</view>
