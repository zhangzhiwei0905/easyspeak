<view class="page quiz-play-page">
  <view class="quiz-play__nav">
    <view class="quiz-play__nav-back" bindtap="onBack">
      <text class="quiz-play__nav-back-text">‹</text>
    </view>
    <view class="quiz-play__nav-center">
      <text class="quiz-play__nav-title" wx:if="{{mode === 'wrong_review'}}">错题回顾</text>
      <text class="quiz-play__nav-title" wx:elif="{{mode === 'theme'}}">主题测验</text>
      <text class="quiz-play__nav-title" wx:else>闪电测验</text>
    </view>
    <view class="quiz-play__nav-right"></view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-dots">
      <view class="loading-dots__dot"></view>
      <view class="loading-dots__dot"></view>
      <view class="loading-dots__dot"></view>
    </view>
    <text class="loading-state__title">{{prepareText}}</text>
    <view class="loading-progress">
      <view class="loading-progress__track">
        <view class="loading-progress__fill" style="width: {{prepareProgress}}%"></view>
      </view>
      <text class="loading-progress__value">{{prepareProgress}}%</text>
    </view>
    <text class="loading-state__text">{{isTimed ? '闪电测验准备中，马上开始计时' : '正在为你整理合适的练习题'}}</text>
  </view>

  <view class="error-state" wx:if="{{loadError && !loading}}">
    <text class="error-state__icon">!</text>
    <text class="error-state__text">{{errorMsg || '加载失败，请重试'}}</text>
    <view class="quiz-play__error-actions">
      <button class="btn btn-primary btn-block" bindtap="onRetry">重新加载</button>
      <button class="btn btn-outline btn-block mt-md" bindtap="onBack">返回</button>
    </view>
  </view>

  <block wx:if="{{!loading && !loadError && question}}">
    <view class="quiz-play__meta">
      <view class="quiz-play__progress">
        <view class="quiz-play__progress-header">
          <text class="quiz-play__progress-label">第 {{currentIndex + 1}} / {{totalQuestions}} 题</text>
          <text class="quiz-play__progress-correct" wx:if="{{correctCount > 0}}">✓ {{correctCount}}</text>
        </view>
        <progress-bar
          current="{{currentIndex + (submitted ? 1 : 0)}}"
          total="{{totalQuestions}}"
          color="#007AFF"
          height="12">
        </progress-bar>
      </view>

      <view class="quiz-play__timer {{timerWarning ? 'quiz-play__timer--warning' : ''}}" wx:if="{{isTimed}}">
        <text class="quiz-play__timer-icon">⏱️</text>
        <text class="quiz-play__timer-text">{{timerDisplay}}</text>
      </view>
    </view>

    <view class="quiz-play__card card animate-fade-in">
      <view class="quiz-play__type-row">
        <text class="quiz-play__type-badge {{questionTypeTone === 'listen' ? 'quiz-play__type-badge--listen' : ''}} {{questionTypeTone === 'reorder' ? 'quiz-play__type-badge--reorder' : ''}}">{{questionTypeLabel}}</text>
      </view>

      <!-- listening_choice: audio play button + prompt -->
      <view class="quiz-play__question" wx:if="{{interactionType === 'listening_choice'}}">
        <view class="quiz-play__audio-area">
          <view class="quiz-play__audio-btn" bindtap="onReplayAudio">
            <text class="quiz-play__audio-icon">🔊</text>
          </view>
          <text class="quiz-play__audio-label">点击重新播放</text>
        </view>
        <text class="quiz-play__question-text">{{prompt}}</text>
      </view>

      <view class="quiz-play__question" wx:else>
        <text class="quiz-play__question-text">{{prompt}}</text>
      </view>

      <view class="quiz-play__options" wx:if="{{interactionType === 'choice' || interactionType === 'listening_choice'}}">
        <view
          class="quiz-play__option {{selectedKey === item.key ? 'quiz-play__option--selected' : ''}} {{submitted && item.isAnswer ? 'quiz-play__option--correct' : ''}} {{submitted && selectedKey === item.key && !isCorrect ? 'quiz-play__option--wrong' : ''}}"
          wx:for="{{options}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="onSelectOption">
          <text class="quiz-play__option-key">{{item.key}}</text>
          <text class="quiz-play__option-text">{{item.text}}</text>
          <text class="quiz-play__option-icon" wx:if="{{submitted && item.isAnswer}}">✓</text>
          <text class="quiz-play__option-icon quiz-play__option-icon--wrong" wx:if="{{submitted && selectedKey === item.key && !isCorrect}}">✗</text>
        </view>
      </view>

      <!-- word_select: 多邻国风格短语选择 -->
      <view class="quiz-play__word-select" wx:if="{{interactionType === 'word_select'}}">
        <!-- 句子展示区（空白替换为选中词或占位） -->
        <view class="quiz-play__sentence">
          <text>{{prompt}}</text>
        </view>
        <!-- 候选词区 -->
        <view class="quiz-play__candidates">
          <view
            class="quiz-play__chip {{selectedKey === item.key ? 'quiz-play__chip--selected' : ''}} {{submitted && item.isAnswer ? 'quiz-play__chip--correct' : ''}} {{submitted && selectedKey === item.key && !isCorrect ? 'quiz-play__chip--wrong' : ''}}"
            wx:for="{{options}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="onSelectOption">
            <text>{{item.text}}</text>
          </view>
        </view>
      </view>

      <!-- reorder: 排序拼句 -->
      <view class="quiz-play__reorder" wx:if="{{interactionType === 'reorder'}}">
        <text class="quiz-play__reorder-label">已选答案</text>
        <view class="quiz-play__reorder-sentence">
          <view class="quiz-play__reorder-slot" wx:for="{{reorderWords}}" wx:key="index" data-index="{{index}}" bindtap="onRemoveReorderWord">
            <text class="quiz-play__reorder-word">{{item}}</text>
            <text class="quiz-play__reorder-remove" wx:if="{{!submitted}}">×</text>
          </view>
          <view class="quiz-play__reorder-placeholder" wx:if="{{reorderSelected.length === 0}}">
            <text>请按顺序点击下方英文单词完成短语拼接</text>
          </view>
        </view>
        <text class="quiz-play__reorder-label">候选词块</text>
        <view class="quiz-play__candidates">
          <view
            class="quiz-play__chip {{item.disabled ? 'quiz-play__chip--disabled' : ''}} {{submitted && isCorrect ? 'quiz-play__chip--correct' : ''}} {{submitted && !isCorrect ? 'quiz-play__chip--wrong' : ''}}"
            wx:for="{{reorderOptions}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="onSelectOption">
            <text>{{item.text}}</text>
          </view>
        </view>
        <view class="quiz-play__reorder-actions" wx:if="{{reorderSelected.length > 0 && !submitted}}">
          <view class="quiz-play__reorder-undo" bindtap="onUndoReorder">
            <text>↩ 撤销</text>
          </view>
        </view>
      </view>

      <view class="quiz-play__feedback" wx:if="{{submitted}}">
        <view class="quiz-play__feedback-banner {{isCorrect ? 'quiz-play__feedback-banner--correct' : 'quiz-play__feedback-banner--wrong'}}">
          <text class="quiz-play__feedback-emoji">{{isCorrect ? '🎉' : '😅'}}</text>
          <text class="quiz-play__feedback-text">{{isCorrect ? '回答正确' : '正确答案：' + correctOptionText}}</text>
        </view>
        <view class="quiz-play__meaning-card" wx:if="{{questionType === 'word_phonetic_choice' && question.hint}}">
          <text class="quiz-play__meaning-label">中文释义</text>
          <text class="quiz-play__meaning-text">{{question.hint}}</text>
        </view>
        <!-- 答错展示解析 -->
        <view class="quiz-play__explanation-toggle" wx:if="{{!isCorrect && question.explanation}}" bindtap="onToggleExplanation">
          <text>{{showExplanation ? '收起解析 ▲' : '查看解析 ▼'}}</text>
        </view>
        <view class="quiz-play__explanation-content" wx:if="{{!isCorrect && showExplanation && question.explanation}}">
          <text>{{question.explanation}}</text>
        </view>
      </view>
    </view>

    <view class="quiz-play__actions safe-bottom">
      <button
        class="btn btn-primary btn-block {{!canSubmit ? 'btn-disabled' : ''}}"
        wx:if="{{!submitted}}"
        bindtap="onSubmitAnswer">
        确认答案
      </button>

      <button
        class="btn btn-primary btn-block"
        wx:if="{{submitted && currentIndex < totalQuestions - 1}}"
        bindtap="onNextQuestion">
        下一题
      </button>

      <button
        class="btn btn-accent btn-block"
        wx:if="{{submitted && currentIndex >= totalQuestions - 1}}"
        bindtap="onNextQuestion">
        查看结果
      </button>
    </view>
  </block>
</view>
