<view class="page quiz-page">
  <view class="quiz-page__hero">
    <text class="quiz-page__title">🎯 测验中心</text>
    <text class="quiz-page__desc">用统一的练习节奏，检验今天的学习成果</text>
  </view>

  <view class="skeleton" wx:if="{{loading}}">
    <view class="skeleton__card" style="height: 220rpx;"></view>
    <view class="skeleton__card" style="height: 360rpx;"></view>
    <view class="skeleton__card" style="height: 220rpx;"></view>
    <view class="skeleton__card" style="height: 280rpx;"></view>
  </view>

  <block wx:if="{{!loading}}">
    <view class="quiz-menu-card card animate-fade-in">
      <view class="quiz-menu-card__header quiz-menu-card__header--clickable" bindtap="onStartLightning">
        <view class="quiz-menu-card__icon quiz-menu-card__icon--lightning">
          <text>⚡</text>
        </view>
        <view class="quiz-menu-card__main">
          <text class="quiz-menu-card__title">闪电测验</text>
          <text class="quiz-menu-card__desc">10道混合题 · 3分钟限时挑战</text>
        </view>
        <text class="quiz-menu-card__arrow">›</text>
      </view>
      <view class="quiz-menu-card__panel">
        <view class="quiz-menu-card__tags">
          <text class="quiz-menu-card__tag">短语释义</text>
          <text class="quiz-menu-card__tag">单词音标</text>
          <text class="quiz-menu-card__tag">短语填空</text>
        </view>
      </view>
    </view>

    <view class="quiz-menu-card card animate-fade-in" style="animation-delay: 0.08s">
      <view class="quiz-menu-card__header quiz-menu-card__header--clickable" bindtap="onToggleThemePicker">
        <view class="quiz-menu-card__icon quiz-menu-card__icon--theme">
          <text>📝</text>
        </view>
        <view class="quiz-menu-card__main">
          <text class="quiz-menu-card__title">主题测验</text>
          <text class="quiz-menu-card__desc">按主题挑选内容，定向检验</text>
        </view>
        <text class="quiz-menu-card__arrow {{showThemePicker ? 'quiz-menu-card__arrow--open' : ''}}">›</text>
      </view>

      <view class="quiz-menu-card__panel" wx:if="{{showThemePicker && themes.length > 0}}">
        <view class="quiz-theme-list">
          <view
            class="quiz-theme-item {{item.selected ? 'quiz-theme-item--selected' : ''}}"
            wx:for="{{themes}}"
            wx:key="content_id"
            data-id="{{item.content_id}}"
            bindtap="onThemeSelect">
            <view class="quiz-theme-item__check">
              <text wx:if="{{item.selected}}">✓</text>
            </view>
            <view class="quiz-theme-item__main">
              <text class="quiz-theme-item__zh">{{item.theme_zh}}</text>
              <text class="quiz-theme-item__en">{{item.theme_en}}</text>
            </view>
            <text class="quiz-theme-item__count">{{item.question_count}}题</text>
          </view>
        </view>
        <view class="quiz-menu-card__footer quiz-menu-card__footer--action" bindtap="onStartThemeQuiz">
          <text class="quiz-menu-card__hint" wx:if="{{selectedThemes.length > 0}}">已选 {{selectedThemes.length}} 个主题</text>
          <text class="quiz-menu-card__hint" wx:else>请选择主题</text>
          <text class="quiz-menu-card__arrow">›</text>
        </view>
      </view>

      <view class="quiz-menu-card__panel quiz-menu-card__panel--empty" wx:if="{{showThemePicker && themes.length === 0}}">
        <text class="quiz-menu-card__empty">暂无主题数据</text>
      </view>
    </view>

    <view class="quiz-menu-card card animate-fade-in {{wrongCount > 0 ? '' : 'quiz-menu-card--disabled'}}" style="animation-delay: 0.16s">
      <view class="quiz-menu-card__header quiz-menu-card__header--clickable" bindtap="onStartWrongReview">
        <view class="quiz-menu-card__icon quiz-menu-card__icon--wrong">
          <text>🔄</text>
        </view>
        <view class="quiz-menu-card__main">
          <text class="quiz-menu-card__title">错题回顾</text>
          <text class="quiz-menu-card__desc" wx:if="{{wrongCount > 0}}">共 {{wrongCount}} 道错题等待挑战</text>
          <text class="quiz-menu-card__desc" wx:else>暂无错题，继续保持</text>
        </view>
        <text class="quiz-menu-card__arrow">›</text>
      </view>
      <view class="quiz-menu-card__panel">
        <view class="quiz-menu-card__status-row">
          <text class="quiz-menu-card__status-label">当前状态</text>
          <text class="quiz-menu-card__status-value {{wrongCount > 0 ? 'quiz-menu-card__status-value--warn' : 'quiz-menu-card__status-value--good'}}">
            {{wrongCount > 0 ? '待复盘' : '已清空'}}
          </text>
        </view>
      </view>
    </view>

    <view class="quiz-menu-card card animate-fade-in" style="animation-delay: 0.24s">
      <view class="quiz-menu-card__header quiz-menu-card__header--clickable" bindtap="onToggleStats">
        <view class="quiz-menu-card__icon quiz-menu-card__icon--stats">
          <text>📊</text>
        </view>
        <view class="quiz-menu-card__main">
          <text class="quiz-menu-card__title">测验统计</text>
          <text class="quiz-menu-card__desc">总答题 {{stats.total_answered}} · 正确率 {{stats.accuracy}}%</text>
        </view>
        <text class="quiz-menu-card__arrow {{showStatsPanel ? 'quiz-menu-card__arrow--open' : ''}}">›</text>
      </view>
      <view class="quiz-menu-card__panel" wx:if="{{showStatsPanel}}">
        <view class="quiz-stats-grid">
          <view class="quiz-stats-item">
            <text class="quiz-stats-item__value">{{stats.total_answered}}</text>
            <text class="quiz-stats-item__label">总答题数</text>
          </view>
          <view class="quiz-stats-item">
            <text class="quiz-stats-item__value">{{stats.accuracy}}%</text>
            <text class="quiz-stats-item__label">正确率</text>
          </view>
          <view class="quiz-stats-item">
            <text class="quiz-stats-item__value">🔥 {{stats.current_streak}}</text>
            <text class="quiz-stats-item__label">当前连胜</text>
          </view>
          <view class="quiz-stats-item">
            <text class="quiz-stats-item__value">🏆 {{stats.max_streak}}</text>
            <text class="quiz-stats-item__label">最高连胜</text>
          </view>
          <view class="quiz-stats-item">
            <text class="quiz-stats-item__value">🌀 {{stats.wrong_count}}</text>
            <text class="quiz-stats-item__label">待清错题</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
