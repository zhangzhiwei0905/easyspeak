.quiz-page {
  background: var(--color-bg);
}

.quiz-page__hero {
  margin-bottom: var(--spacing-lg);
}

.quiz-page__title {
  display: block;
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
}

.quiz-page__desc {
  display: block;
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

.skeleton__card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  margin-bottom: var(--spacing-lg);
  position: relative;
  overflow: hidden;
}

.skeleton__card::after {
  content: '';
  position: absolute;
  top: 0;
  left: -50%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(102, 126, 234, 0.06), transparent);
  animation: shimmer 1.5s ease-in-out infinite;
}

@keyframes shimmer {
  0% { left: -50%; }
  100% { left: 150%; }
}

.quiz-menu-card {
  margin-bottom: var(--spacing-lg);
}

.quiz-menu-card--disabled {
  opacity: 0.82;
}

.quiz-menu-card__header {
  display: flex;
  align-items: center;
}

.quiz-menu-card__header--clickable:active {
  opacity: 0.86;
}

.quiz-menu-card__icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
  font-size: 40rpx;
  flex-shrink: 0;
}

.quiz-menu-card__icon--lightning {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

.quiz-menu-card__icon--theme {
  background: linear-gradient(135deg, #dceeff 0%, #e6ddff 100%);
}

.quiz-menu-card__icon--wrong {
  background: linear-gradient(135deg, #ffe0de 0%, #ffe8f0 100%);
}

.quiz-menu-card__icon--stats {
  background: linear-gradient(135deg, #e6f4ff 0%, #eef3ff 100%);
}

.quiz-menu-card__main {
  flex: 1;
  min-width: 0;
}

.quiz-menu-card__title {
  display: block;
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.quiz-menu-card__desc {
  display: block;
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  line-height: 1.45;
}

.quiz-menu-card__arrow {
  font-size: 36rpx;
  color: var(--color-text-hint);
  font-weight: 300;
  margin-left: var(--spacing-sm);
  transition: transform 0.3s ease;
}

.quiz-menu-card__arrow--open {
  transform: rotate(-90deg);
}

.quiz-menu-card__panel {
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1rpx solid var(--color-border);
}

.quiz-menu-card__panel--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 120rpx;
}

.quiz-menu-card__empty {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

.quiz-menu-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quiz-menu-card__tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 22rpx;
  background: #f5f6fa;
  border-radius: var(--radius-round);
  font-size: var(--font-size-small);
  color: var(--color-text-secondary);
}

.quiz-menu-card__actions {
  margin-top: var(--spacing-md);
}

.quiz-theme-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.quiz-theme-item {
  display: flex;
  align-items: center;
  padding: 18rpx 16rpx;
  border-radius: var(--radius-md);
  background: #f8f9fc;
  border: 2rpx solid transparent;
}

.quiz-theme-item--selected {
  border-color: rgba(102, 126, 234, 0.3);
  background: rgba(102, 126, 234, 0.06);
}

.quiz-theme-item__check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-sm);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.quiz-theme-item--selected .quiz-theme-item__check {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.quiz-theme-item__main {
  flex: 1;
  min-width: 0;
}

.quiz-theme-item__zh {
  display: block;
  font-size: var(--font-size-body);
  font-weight: 500;
  color: var(--color-text-primary);
}

.quiz-theme-item__en {
  display: block;
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
  margin-top: 2rpx;
}

.quiz-theme-item__count {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  margin-left: var(--spacing-sm);
  flex-shrink: 0;
}

.quiz-menu-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--spacing-md);
  gap: var(--spacing-sm);
}

.quiz-menu-card__footer--action {
  min-height: 72rpx;
}

.quiz-menu-card__footer--action:active {
  opacity: 0.86;
}

.quiz-menu-card__hint {
  font-size: var(--font-size-caption);
  color: var(--color-primary);
  font-weight: 500;
}

.quiz-menu-card__status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.quiz-menu-card__status-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

.quiz-menu-card__status-value {
  font-size: var(--font-size-body);
  font-weight: 600;
}

.quiz-menu-card__status-value--warn {
  color: var(--color-accent);
}

.quiz-menu-card__status-value--good {
  color: var(--color-success);
}

.quiz-stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quiz-stats-item {
  flex: 1;
  min-width: 140rpx;
  padding: 20rpx 16rpx;
  background: #f8f9fc;
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quiz-stats-item__value {
  font-size: var(--font-size-title);
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 4rpx;
}

.quiz-stats-item__label {
  font-size: var(--font-size-small);
  color: var(--color-text-hint);
}
