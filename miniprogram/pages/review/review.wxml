<view class="review-page" wx:if="{{mode === 'overview'}}">
  <view class="review-header {{!loading && !overviewLoadFailed && dueCount === 0 ? 'review-header--completed' : ''}}">
    <view class="review-header__glow review-header__glow--one"></view>
    <view class="review-header__glow review-header__glow--two"></view>

    <view class="review-header__content">
      <view class="review-header__topline">
        <view class="review-header__icon-wrap">
          <text class="review-header__icon">{{!loading && !overviewLoadFailed && dueCount === 0 ? '✅' : '🧠'}}</text>
        </view>
        <text class="review-header__tag">Spaced Repetition</text>
      </view>

      <text class="review-header__title" wx:if="{{loading}}">智能复习</text>
      <text class="review-header__title" wx:elif="{{overviewLoadFailed}}">复习状态待同步</text>
      <text class="review-header__title" wx:elif="{{dueCount > 0}}">该给记忆充充电了</text>
      <text class="review-header__title" wx:else>今天的记忆状态很好</text>

      <text class="review-header__subtitle" wx:if="{{loading}}">正在同步你的复习计划...</text>
      <text class="review-header__subtitle" wx:elif="{{overviewLoadFailed}}">复习状态加载失败，点击下方按钮重试</text>
      <text class="review-header__subtitle" wx:elif="{{todayReviewCount > 0}}">今天共有 {{todayReviewCount}} 项要复习</text>
      <text class="review-header__subtitle" wx:else>当日复习内容已完成，明天再来巩固一下</text>

      <view class="review-header__status">
        <text class="review-header__status-label" wx:if="{{loading}}">今日状态</text>
        <text class="review-header__status-label" wx:elif="{{overviewLoadFailed}}">同步状态</text>
        <text class="review-header__status-label" wx:elif="{{todayReviewCount > 0}}">今日复习</text>
        <text class="review-header__status-label" wx:else>今日状态</text>
        <text class="review-header__status-value" wx:if="{{loading}}">同步中</text>
        <text class="review-header__status-value" wx:elif="{{overviewLoadFailed}}">待重试</text>
        <text class="review-header__status-value" wx:elif="{{todayReviewCount > 0}}">{{todayReviewCount}} 项</text>
        <text class="review-header__status-value" wx:else>已完成</text>
      </view>
    </view>
  </view>

  <view class="review-section">
    <view class="review-section__title">
      <text class="review-section__icon">📅</text>
      <text>复习日历</text>
    </view>
    <calendar
      calendarData="{{calendarData}}"
      currentMonth="{{currentMonth}}"
      bind:monthchange="onMonthChange"
      bind:daytap="onDayTap"
    />
  </view>

  <view class="review-section">
    <view class="review-section__title">
      <text class="review-section__icon">📊</text>
      <text>记忆曲线概览</text>
    </view>

    <view class="memory-stats">
      <view class="memory-stat memory-stat--forgetting">
        <view class="memory-stat__left">
          <view class="memory-stat__dot memory-stat__dot--red"></view>
          <text class="memory-stat__label">即将遗忘</text>
        </view>
        <text class="memory-stat__count">{{summary.forgetting_count || 0}}</text>
        <text class="memory-stat__hint">1天内到期</text>
      </view>

      <view class="memory-stat memory-stat--consolidating">
        <view class="memory-stat__left">
          <view class="memory-stat__dot memory-stat__dot--yellow"></view>
          <text class="memory-stat__label">巩固中</text>
        </view>
        <text class="memory-stat__count">{{summary.consolidating_count || 0}}</text>
        <text class="memory-stat__hint">3天内到期</text>
      </view>

      <view class="memory-stat memory-stat--mastered">
        <view class="memory-stat__left">
          <view class="memory-stat__dot memory-stat__dot--green"></view>
          <text class="memory-stat__label">已掌握</text>
        </view>
        <text class="memory-stat__count">{{summary.mastered_count || 0}}</text>
        <text class="memory-stat__hint">3天后复习</text>
      </view>

      <view class="memory-stat memory-stat--new">
        <view class="memory-stat__left">
          <view class="memory-stat__dot memory-stat__dot--gray"></view>
          <text class="memory-stat__label">新内容</text>
        </view>
        <text class="memory-stat__count">{{summary.new_count || 0}}</text>
        <text class="memory-stat__hint">从未复习</text>
      </view>
    </view>
  </view>

  <view class="review-action">
    <button
      class="review-btn {{loading ? 'review-btn--disabled' : 'review-btn--active'}}"
      wx:if="{{loading || overviewLoadFailed || dueCount > 0}}"
      bindtap="startReview"
      disabled="{{loading}}"
    >
      <text class="review-btn__icon">🔄</text>
      <text class="review-btn__text">开始复习</text>
      <text class="review-btn__count" wx:if="{{loading}}">加载中...</text>
      <text class="review-btn__count" wx:elif="{{overviewLoadFailed}}">点击重试</text>
      <text class="review-btn__count" wx:else>{{dueCount}}项要复习</text>
    </button>
    <view class="review-completed-text" wx:else>
      <text>✅ 当日复习内容已完成</text>
    </view>
  </view>


  <view class="review-loading" wx:if="{{loading}}">
    <view class="review-loading__spinner"></view>
    <text class="review-loading__text">加载中...</text>
  </view>
</view>

<view class="review-session" wx:if="{{mode === 'session'}}">
  <view class="session-header">
    <view class="session-header__top">
      <view class="session-header__back" bindtap="exitSession">
        <text>✕</text>
      </view>
      <text class="session-header__title">复习测验 · {{reviewStageLabel}}</text>
      <view class="session-header__placeholder"></view>
    </view>
    <view class="session-header__progress-text">
      <text>第 {{currentIndex + 1}} / {{totalQuestionCount}} 题 · {{currentItem.text}}</text>
    </view>
    <progress-bar
      current="{{currentIndex + 1}}"
      total="{{totalQuestionCount}}"
      color="#667eea"
      height="{{12}}"
    />
  </view>

  <view class="review-quiz-card">
    <view class="review-quiz-card__badge {{currentItem.item_type === 'word' ? 'review-quiz-card__badge--word' : ''}}">
      <text>{{currentItem.item_type === 'phrase' ? '💬 短语' : '📖 单词'}}</text>
    </view>

    <block wx:if="{{reviewStage === 2 || reviewStage === 3}}">
      <text class="review-quiz-card__hint">{{quizData.hint || (reviewStage === 2 ? '根据中文选择英文' : '根据英文句子选择中文')}}</text>
      <text class="review-quiz-card__question">{{quizData.question}}</text>

      <view class="review-options">
        <view
          class="review-option {{selectedKey === item.key ? 'review-option--selected' : ''}} {{submitted && item.key === quizData.answer ? 'review-option--correct' : ''}} {{submitted && selectedKey === item.key && item.key !== quizData.answer ? 'review-option--wrong' : ''}}"
          wx:for="{{quizData.options}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="onReviewSelectOption"
        >
          <text class="review-option__key">{{item.key}}</text>
          <text class="review-option__text">{{item.text}}</text>
        </view>
      </view>

      <view class="review-feedback {{isCorrect ? 'review-feedback--correct' : 'review-feedback--wrong'}}" wx:if="{{submitted}}">
        <text>{{isCorrect ? '✅ 答对了' : '❌ 正确答案：' + correctOptionText}}</text>
      </view>

      <button
        class="review-next-btn"
        wx:if="{{!submitted}}"
        bindtap="onReviewSubmitChoice"
      >提交答案</button>
      <button
        class="review-next-btn review-next-btn--active"
        wx:else
        bindtap="onReviewChoiceNext"
      >继续</button>
    </block>

    <block wx:if="{{reviewStage === 4}}">
      <text class="review-quiz-card__hint">最终确认</text>
      <text class="review-quiz-card__question">{{finalQuiz.prompt}}</text>

      <block wx:if="{{finalQuiz.type === 'word_select'}}">
        <view class="review-slots">
          <view
            class="review-slot {{slot.isCorrect === true ? 'review-slot--correct' : ''}} {{slot.isCorrect === false ? 'review-slot--wrong' : ''}}"
            wx:for="{{wordSlots}}"
            wx:for-item="slot"
            wx:key="index"
            data-index="{{index}}"
            bindtap="onReviewSlotTap"
          >
            <text>{{slot.text || ' '}}</text>
          </view>
        </view>
        <view class="review-keyboard">
          <view
            class="review-key {{tile.used ? 'review-key--used' : ''}}"
            wx:for="{{availableTiles}}"
            wx:for-item="tile"
            wx:key="index"
            data-index="{{index}}"
            bindtap="onReviewWordTileTap"
          >{{tile.text}}</view>
        </view>
        <view class="review-feedback {{wordSelectSubmitted && wordSlots[0].isCorrect ? 'review-feedback--correct' : 'review-feedback--wrong'}}" wx:if="{{wordSelectSubmitted}}">
          <text>正确短语：{{finalQuiz.correct_phrase}}</text>
        </view>
      </block>

      <block wx:if="{{finalQuiz.type === 'spelling_keyboard'}}">
        <view class="review-slots review-slots--letters">
          <view
            class="review-slot review-slot--letter {{slot.isCorrect === true ? 'review-slot--correct' : ''}} {{slot.isCorrect === false ? 'review-slot--wrong' : ''}}"
            wx:for="{{spellingSlots}}"
            wx:for-item="slot"
            wx:key="index"
            data-index="{{index}}"
            bindtap="onSpellingSlotTap"
          >
            <text>{{slot.text || ' '}}</text>
          </view>
        </view>
        <view class="review-keyboard review-keyboard--letters">
          <view
            class="review-key review-key--letter {{letter.used ? 'review-key--used' : ''}}"
            wx:for="{{keyboardLetters}}"
            wx:for-item="letter"
            wx:key="index"
            data-index="{{index}}"
            bindtap="onKeyboardLetterTap"
          >{{letter.text}}</view>
        </view>
        <view class="review-feedback {{spellingCorrect ? 'review-feedback--correct' : 'review-feedback--wrong'}}" wx:if="{{spellingSubmitted}}">
          <text>{{spellingCorrect ? '✅ 拼写正确' : '❌ 正确拼写：' + finalQuiz.answer}}</text>
        </view>
      </block>

      <button
        class="review-next-btn {{(wordSelectSubmitted || spellingSubmitted) ? 'review-next-btn--active' : 'review-next-btn--disabled'}}"
        bindtap="onFinalNext"
      >继续</button>
    </block>
  </view>

  <view class="session-submitting" wx:if="{{submitting}}">
    <view class="review-loading__spinner"></view>
    <text>提交中...</text>
  </view>
</view>

<view class="review-summary" wx:if="{{mode === 'summary'}}">
  <view class="summary-card">
    <view class="summary-card__icon">🎉</view>
    <text class="summary-card__title">复习完成！</text>

    <view class="summary-stats">
      <view class="summary-stat">
        <text class="summary-stat__value">{{summaryResult.reviewedCount}}</text>
        <text class="summary-stat__label">已复习</text>
      </view>
      <view class="summary-stat__divider"></view>
      <view class="summary-stat">
        <text class="summary-stat__value">{{summaryResult.avgMastery}}</text>
        <text class="summary-stat__label">平均掌握度</text>
      </view>
      <view class="summary-stat__divider"></view>
      <view class="summary-stat">
        <text class="summary-stat__value summary-stat__value--{{summaryResult.masteryLevel}}">{{summaryResult.masteryLabel}}</text>
        <text class="summary-stat__label">总体评价</text>
      </view>
    </view>

    <view class="summary-distribution">
      <text class="summary-distribution__title">掌握度分布</text>
      <view class="summary-distribution__bars">
        <view class="dist-row" wx:for="{{summaryResult.distribution}}" wx:key="level">
          <text class="dist-row__label">{{item.emoji}} {{item.label}}</text>
          <view class="dist-row__bar-track">
            <view class="dist-row__bar-fill" style="width: {{item.pct}}%;"></view>
          </view>
          <text class="dist-row__count">{{item.count}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="summary-actions">
    <button class="summary-btn summary-btn--again" bindtap="reviewAgain">
      <text>🔄 再来一轮</text>
    </button>
    <button class="summary-btn summary-btn--quiz" bindtap="goToQuiz">
      <text>🎯 去测一测</text>
    </button>
    <button class="summary-btn summary-btn--back" bindtap="backToOverview">
      <text>🏠 返回复习首页</text>
    </button>
  </view>
</view>

<!-- Day detail popup -->
<view class="day-detail-mask {{showDayDetail ? 'day-detail-mask--show' : ''}}" bindtap="closeDayDetail">
  <view class="day-detail-popup {{showDayDetail ? 'day-detail-popup--show' : ''}}" catchtap="">
    <view class="day-detail__header">
      <text class="day-detail__date">{{dayDetail.dateStr}}</text>
      <view class="day-detail__close" bindtap="closeDayDetail">
        <text>✕</text>
      </view>
    </view>
    <view class="day-detail__body" wx:if="{{dayDetail.hasReview || dayDetail.hasContent}}">
      <view class="day-detail__section day-detail__section--review" wx:if="{{dayDetail.hasReview}}">
        <text class="day-detail__section-title">当日复习</text>
        <view class="day-detail__stats day-detail__stats--review">
          <view class="day-detail__stat">
            <text class="day-detail__stat-icon">🔄</text>
            <text class="day-detail__stat-value">{{dayDetail.reviewedCount}}</text>
            <text class="day-detail__stat-label">项复习</text>
          </view>
          <view class="day-detail__stat">
            <text class="day-detail__stat-icon">💬</text>
            <text class="day-detail__stat-value">{{dayDetail.reviewPhraseCount}}</text>
            <text class="day-detail__stat-label">短语</text>
          </view>
          <view class="day-detail__stat">
            <text class="day-detail__stat-icon">📖</text>
            <text class="day-detail__stat-value">{{dayDetail.reviewWordCount}}</text>
            <text class="day-detail__stat-label">单词</text>
          </view>
        </view>
        <view class="day-detail__metrics">
          <view class="day-detail__metric">
            <text class="day-detail__metric-label">平均掌握度</text>
            <text class="day-detail__metric-value">{{dayDetail.avgMastery}}/4</text>
          </view>
        </view>
        <view class="day-detail__distribution">
          <view class="day-detail__dist-item">
            <text class="day-detail__dist-label">完全忘了</text>
            <text class="day-detail__dist-value">{{dayDetail.forgotCount}}</text>
          </view>
          <view class="day-detail__dist-item">
            <text class="day-detail__dist-label">有点印象</text>
            <text class="day-detail__dist-value">{{dayDetail.fuzzyCount}}</text>
          </view>
          <view class="day-detail__dist-item">
            <text class="day-detail__dist-label">想起来了/熟悉</text>
            <text class="day-detail__dist-value">{{dayDetail.rememberedCount}}</text>
          </view>
          <view class="day-detail__dist-item">
            <text class="day-detail__dist-label">完全掌握</text>
            <text class="day-detail__dist-value">{{dayDetail.solidCount}}</text>
          </view>
        </view>
      </view>

      <view class="day-detail__section" wx:if="{{dayDetail.hasContent}}">
        <text class="day-detail__section-title">当日新内容</text>
        <text class="day-detail__theme">{{dayDetail.themeZh}}</text>
        <view class="day-detail__stats">
          <view class="day-detail__stat">
            <text class="day-detail__stat-icon">💬</text>
            <text class="day-detail__stat-value">{{dayDetail.phraseCount}}</text>
            <text class="day-detail__stat-label">个短语</text>
          </view>
          <view class="day-detail__stat">
            <text class="day-detail__stat-icon">📖</text>
            <text class="day-detail__stat-value">{{dayDetail.wordCount}}</text>
            <text class="day-detail__stat-label">个单词</text>
          </view>
          <view class="day-detail__stat" wx:if="{{dayDetail.firstPassRate !== null && dayDetail.firstPassRate !== undefined}}">
            <text class="day-detail__stat-icon">🎯</text>
            <text class="day-detail__stat-value">{{dayDetail.firstPassRate}}%</text>
            <text class="day-detail__stat-label">一次通过</text>
          </view>
        </view>
      </view>
    </view>
    <view class="day-detail__empty" wx:else>
      <text class="day-detail__empty-text">该日暂无学习记录</text>
    </view>
  </view>
</view>
