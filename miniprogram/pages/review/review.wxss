/* ========================================
   Review Page Styles
   ======================================== */

/* --- Page Base --- */
.review-page,
.review-session,
.review-summary {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========================================
   Mode 1: Overview
   ======================================== */

/* Page Header */
.review-header {
  position: relative;
  margin: 0 0 4rpx;
  padding: 44rpx 28rpx 38rpx;
  min-height: 270rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  overflow: hidden;
  box-sizing: border-box;
}

.review-header--completed {
  background: linear-gradient(135deg, #3bbf7b 0%, #2e7d32 100%);
}

.review-header__glow {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
}

.review-header__glow--one {
  width: 260rpx;
  height: 260rpx;
  top: -92rpx;
  right: -58rpx;
}

.review-header__glow--two {
  width: 180rpx;
  height: 180rpx;
  left: -52rpx;
  bottom: -76rpx;
  background: rgba(255, 255, 255, 0.12);
}

.review-header__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.review-header__topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 26rpx;
}

.review-header__icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.22);
}

.review-header__icon {
  font-size: 40rpx;
  line-height: 1;
}

.review-header__tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.review-header__title {
  display: block;
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 14rpx;
  letter-spacing: 0.5rpx;
}

.review-header__subtitle {
  display: block;
  max-width: 560rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.78);
}

.review-header__status {
  margin-top: 28rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  align-self: flex-start;
  gap: 14rpx;
  background: rgba(255, 255, 255, 0.18);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.18);
}

.review-header__status-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.review-header__status-value {
  font-size: 28rpx;
  font-weight: 800;
  color: #ffffff;
}

/* Section Container */
.review-section {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.review-section__title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

.review-section__icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* Memory Curve Stats */
.memory-stats {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.memory-stat {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #fafbfc;
}

.memory-stat__left {
  display: flex;
  align-items: center;
  flex: 1;
}

.memory-stat__dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.memory-stat__dot--red { background: #ff6b6b; }
.memory-stat__dot--yellow { background: #ffd93d; }
.memory-stat__dot--green { background: #6bcb77; }
.memory-stat__dot--gray { background: #c8ccd4; }

.memory-stat__label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.memory-stat__count {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin: 0 20rpx;
  min-width: 60rpx;
  text-align: center;
}

.memory-stat__hint {
  font-size: 22rpx;
  color: #999;
  min-width: 120rpx;
  text-align: right;
}

/* Start Review Button */
.review-action {
  padding: 32rpx 24rpx;
}

.review-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: nowrap;
  gap: 12rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

.review-btn--active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.review-btn--disabled {
  background: #e0e3ea;
  color: #999;
}

.review-btn::after {
  border: none;
}

.review-completed-text {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  color: #2e7d32;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0;
  text-align: center;
}

.review-btn__icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.review-btn__text {
  flex-shrink: 0;
}

.review-btn__count {
  font-size: 24rpx;
  font-weight: 400;
  opacity: 0.85;
  flex-shrink: 0;
  white-space: nowrap;
}

/* Loading State */
.review-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.review-loading__spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e3ea;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: review-spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

.review-loading__text {
  font-size: 26rpx;
  color: #999;
}

@keyframes review-spin {
  to { transform: rotate(360deg); }
}

/* ========================================
   Mode 2: Review Session
   ======================================== */

/* Session Header */
.session-header {
  background: #ffffff;
  padding: 24rpx 32rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.session-header__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.session-header__back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #666;
  border-radius: 50%;
  background: #f5f6fa;
}

.session-header__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.session-header__placeholder {
  width: 56rpx;
}

.session-header__progress-text {
  text-align: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #999;
}

/* Card Area */
.session-card-area {
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: center;
}

/* Flip Card — inspired by word-card component */
.flip-card {
  width: 100%;
  height: 480rpx;
  perspective: 1200rpx;
}

.flip-card__inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
}

.flip-card__inner--flipped {
  transform: rotateY(180deg);
}

.flip-card__face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 20rpx;
  overflow: hidden;
}

/* Card Front */
.flip-card__face--front {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.3);
}

.flip-card__front-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.flip-card__type-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.flip-card__type-badge--word {
  background: rgba(255, 255, 255, 0.15);
}

.flip-card__text {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
  text-align: center;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.flip-card__phonetic {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 32rpx;
}

.flip-card__hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* Card Back */
.flip-card__face--back {
  background: #ffffff;
  transform: rotateY(180deg);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.08);
}

.flip-card__back-scroll {
  width: 100%;
  height: 100%;
}

.flip-card__back-content {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.flip-card__back-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.flip-card__back-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.flip-card__back-pos {
  display: inline-block;
  font-size: 22rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-style: italic;
  flex-shrink: 0;
}

/* Meaning Block */
.flip-card__meaning-block {
  margin-bottom: 20rpx;
}

.flip-card__meaning-label,
.flip-card__explanation-label,
.flip-card__examples-label,
.flip-card__example-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.flip-card__meaning {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
}

/* Explanation Block */
.flip-card__explanation-block {
  margin-bottom: 20rpx;
}

.flip-card__explanation {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

/* Examples Block */
.flip-card__examples-block,
.flip-card__example-block {
  margin-bottom: 16rpx;
}

.flip-card__example {
  margin-bottom: 12rpx;
}

.flip-card__example-text {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  font-style: italic;
  background: #f8f9fc;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
}

/* Source */
.flip-card__source-block {
  margin-top: 8rpx;
}

.flip-card__source {
  font-size: 22rpx;
  color: #aaa;
  font-style: italic;
}

.flip-card__hint-back {
  font-size: 22rpx;
  color: #ccc;
  text-align: center;
  margin-top: auto;
  padding-top: 16rpx;
}

/* Mastery Area */
.mastery-area {
  padding: 0 24rpx 40rpx;
  opacity: 0;
  transform: translateY(30rpx);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
}

.mastery-area--visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.mastery-area__label {
  display: block;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.mastery-buttons {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.mastery-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.mastery-btn:active {
  transform: scale(0.97);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.1);
}

.mastery-btn__emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.mastery-btn__label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

/* Mastery button subtle color hints */
.mastery-btn--0 { border-left: 6rpx solid #ff6b6b; }
.mastery-btn--1 { border-left: 6rpx solid #ffa94d; }
.mastery-btn--2 { border-left: 6rpx solid #ffd93d; }
.mastery-btn--3 { border-left: 6rpx solid #69db7c; }
.mastery-btn--4 { border-left: 6rpx solid #667eea; }

/* Submitting State */
.session-submitting {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #999;
}

/* ========================================
   Mode 3: Summary
   ======================================== */

.review-summary {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
}

.summary-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-card__icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.summary-card__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 40rpx;
}

/* Summary Stats Row */
.summary-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 40rpx;
}

.summary-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-stat__value {
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 8rpx;
}

.summary-stat__value--excellent { color: #6bcb77; }
.summary-stat__value--good { color: #667eea; }
.summary-stat__value--fair { color: #ffa94d; }
.summary-stat__value--poor { color: #ff6b6b; }

.summary-stat__label {
  font-size: 22rpx;
  color: #999;
}

.summary-stat__divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
  flex-shrink: 0;
}

/* Mastery Distribution */
.summary-distribution {
  width: 100%;
  padding-top: 40rpx;
  border-top: 1rpx solid #f0f0f0;
}

.summary-distribution__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 28rpx;
}

.summary-distribution__bars {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dist-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 6rpx 0;
}

.dist-row__label {
  font-size: 24rpx;
  color: #666;
  width: 180rpx;
  flex-shrink: 0;
}

.dist-row__bar-track {
  flex: 1;
  height: 16rpx;
  background: #f0f2f5;
  border-radius: 8rpx;
  overflow: hidden;
}

.dist-row__bar-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  min-width: 0;
}

.dist-row__count {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  width: 48rpx;
  text-align: right;
  flex-shrink: 0;
}

/* Summary Actions */
.summary-actions {
  width: 100%;
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.summary-btn--again {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

.summary-btn--quiz {
  background: linear-gradient(135deg, #ffa94d 0%, #ff7a59 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(255, 148, 77, 0.28);
}

.summary-btn--back {
  background: #ffffff;
  color: #667eea;
  border: 2rpx solid #667eea;
  box-sizing: border-box;
}

/* ================================================
   Day detail popup (half-screen)
   ================================================ */

.day-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  pointer-events: none;
  transition: background 0.3s;
}

.day-detail-mask--show {
  background: rgba(0, 0, 0, 0.4);
  pointer-events: auto;
}

.day-detail-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1001;
  max-height: 70vh;
  overflow-y: auto;
  box-sizing: border-box;
}

.day-detail-popup--show {
  transform: translateY(0);
}

.day-detail__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.day-detail__date {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.day-detail__close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
}

.day-detail__section {
  padding: 24rpx 0;
  border-top: 1rpx solid #f0f2f5;
}

.day-detail__section:first-child {
  padding-top: 0;
  border-top: 0;
}

.day-detail__section--review {
  background: rgba(102, 126, 234, 0.04);
  border-radius: 20rpx;
  padding: 24rpx;
  border-top: 0;
  margin-bottom: 20rpx;
}

.day-detail__section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 18rpx;
}

.day-detail__theme {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 24rpx;
}

.day-detail__stats {
  display: flex;
  flex-wrap: wrap;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.day-detail__stats--review {
  gap: 24rpx;
}

.day-detail__stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.day-detail__stat-icon {
  font-size: 28rpx;
}

.day-detail__stat-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.day-detail__stat-label {
  font-size: 24rpx;
  color: #999;
}

.day-detail__metrics {
  display: flex;
  gap: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f2f5;
}

.day-detail__metric {
  flex: 1;
  text-align: center;
}

.day-detail__metric-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.day-detail__metric-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
}

.day-detail__distribution {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.day-detail__dist-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
}

.day-detail__dist-label {
  font-size: 22rpx;
  color: #666;
}

.day-detail__dist-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.day-detail__empty {
  padding: 40rpx 0;
  text-align: center;
}

.day-detail__empty-text {
  font-size: 28rpx;
  color: #999;
}

/* Review quiz flow */
.review-quiz-card {
  margin: 32rpx 24rpx;
  padding: 36rpx 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
}

.review-quiz-card__badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(102, 126, 234, 0.12);
  color: #667eea;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.review-quiz-card__badge--word {
  background: rgba(46, 125, 50, 0.12);
  color: #2e7d32;
}

.review-quiz-card__hint {
  display: block;
  font-size: 24rpx;
  color: #8b8fa3;
  margin-bottom: 16rpx;
}

.review-quiz-card__question {
  display: block;
  white-space: pre-wrap;
  font-size: 34rpx;
  line-height: 1.55;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 32rpx;
}

.review-options {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.review-option {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e6e8f0;
  background: #fafbff;
}

.review-option--selected {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.08);
}

.review-option--correct {
  border-color: #2e7d32;
  background: rgba(46, 125, 50, 0.1);
}

.review-option--wrong {
  border-color: #d92d20;
  background: rgba(217, 45, 32, 0.08);
}

.review-option__key {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eef1ff;
  color: #667eea;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  flex-shrink: 0;
}

.review-option__text {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.45;
  color: #2b2d42;
}

.review-feedback {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.45;
}

.review-feedback--correct {
  color: #1b7f3a;
  background: rgba(46, 125, 50, 0.1);
}

.review-feedback--wrong {
  color: #c2410c;
  background: rgba(234, 88, 12, 0.1);
}

.review-next-btn {
  margin-top: 32rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
}

.review-next-btn::after {
  border: none;
}

.review-next-btn--disabled {
  background: #d9dce8;
  color: #8b8fa3;
}

.review-slots {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  min-height: 88rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f5f6fa;
  margin-bottom: 28rpx;
}

.review-slots--letters {
  justify-content: center;
}

.review-slot {
  min-width: 100rpx;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx dashed #cfd3e1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.review-slot--letter {
  min-width: 56rpx;
  width: 56rpx;
  padding: 0;
  text-transform: uppercase;
}

.review-slot--correct {
  border-style: solid;
  border-color: #2e7d32;
  background: rgba(46, 125, 50, 0.1);
}

.review-slot--wrong {
  border-style: solid;
  border-color: #d92d20;
  background: rgba(217, 45, 32, 0.08);
}

.review-keyboard {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  padding-top: 8rpx;
}

.review-key {
  padding: 18rpx 24rpx;
  min-width: 72rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 2rpx solid #dfe3f2;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #2b2d42;
}

.review-key--letter {
  width: 72rpx;
  padding: 18rpx 0;
  text-transform: uppercase;
}

.review-key--used {
  opacity: 0.25;
}
